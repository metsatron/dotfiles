#!/usr/bin/env bash
set -euo pipefail
repo="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
helper="${HOME}/.local/bin/dotcortex-git-guard"
[ -x "$helper" ] || helper="$repo/all/.local/bin/dotcortex-git-guard"
exec "$helper"
