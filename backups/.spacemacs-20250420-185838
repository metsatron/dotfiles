(defun dotspacemacs/user-config ()
  (message "User-config running!")
  (split-window-right -80 t)
  (message "Loading HelmCortex...")
  (find-file "~/Nextcloud/HelmCortex.org")
  (message "Moving right...")
  (windmove-right)
  (message "Loading dashboard...")
  (find-file "~/Nextcloud/Clients/Enterprise/dashboard.org")
  (message "Setting org-mode...")
  (org-mode)
  (message "Running clock-report...")
  (org-clock-report)
  (message "Running agenda...")
  (org-agenda-list 7)
  (message "Done!"))
