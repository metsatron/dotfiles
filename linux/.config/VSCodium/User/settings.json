{
  "vscode-neovim.neovimExecutablePaths.linux": "nvim",
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  },
  "vscode-neovim.debugLogging": true,
  "terminal.integrated.profiles.linux": {
    "Guix zsh (sandbox)": {
      "path": "/bin/sh",
      "args": [
        "-lc",
        "exec \"$HOME/.guix-extra-profiles/core/core/bin/zsh\" -l"
      ],
      "overrideName": true
    },
    "Guix zsh (host)": {
      "path": "/usr/bin/flatpak-spawn",
      "args": [
        "--host",
        "/bin/sh",
        "-lc",
        "exec \"$HOME/.guix-extra-profiles/core/core/bin/zsh\" -l"
      ],
      "overrideName": true
    }
  },
  "terminal.integrated.defaultProfile.linux": "Guix zsh (sandbox)",
  "terminal.integrated.inheritEnv": false,
  "editor.fontFamily": "'SF Mono','SFMono Nerd Font','JetBrainsMono Nerd Font',Menlo,Monaco,'Courier New',monospace",
  "editor.fontLigatures": true,
  "terminal.integrated.fontFamily": "'SFMono Nerd Font Mono','SF Mono','SFMono Nerd Font',monospace",
  "markdown.preview.fontFamily": "'SF Pro Text','SF Pro Display','San Francisco',-apple-system,system-ui,sans-serif",
  "notebook.output.fontFamily": "'SF Pro Text','San Francisco',-apple-system,system-ui,sans-serif",
  "workbench.fontAliasing": "antialiased",
  "workbench.colorTheme": "LainCore",
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,
  "workbench.iconTheme": "se98",
  "workbench.productIconTheme": "Tabler",
  "workbench.activityBar.location": "top",
  "vscode-neovim.compositeKeys": {},
  "workbench.secondarySideBar.defaultVisibility": "visible"
}