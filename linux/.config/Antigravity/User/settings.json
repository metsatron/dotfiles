{
  "claudeCode.preferredLocation": "panel",

  "terminal.integrated.commandsToSkipShell": [
    "workbench.action.terminal.sendSequence"
  ],

  "terminal.integrated.profiles.linux": {
    "bash": {
      "path": "bash",
      "icon": "terminal-bash"
    },
    "zsh": {
      "path": "/home/metsatron/.guix-extra-profiles/core/core/bin/zsh"
    },
    "fish": {
      "path": "fish"
    },
    "tmux": {
      "path": "tmux",
      "icon": "terminal-tmux"
    },
    "pwsh": {
      "path": "pwsh",
      "icon": "terminal-powershell"
    },
    "Guix zsh (sandbox)": {
      "path": "/bin/sh",
      "args": [
        "-lc",
        "exec \"$HOME/.guix-extra-profiles/core/core/bin/zsh\" -l"
      ],
      "overrideName": true
    },
    "Guix zsh (host)": {
      "path": "/usr/bin/flatpak-spawn",
      "args": [
        "--host",
        "/bin/sh",
        "-lc",
        "exec \"$HOME/.guix-extra-profiles/core/core/bin/zsh\" -l"
      ],
      "overrideName": true
    }
  },
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.inheritEnv": false,
  "terminal.integrated.env.linux": { "LD_PRELOAD": "" },
  "terminal.integrated.fontFamily": "'SFMono Nerd Font Mono','SF Mono','SFMono Nerd Font',monospace",

  "editor.fontFamily": "'SF Mono','SFMono Nerd Font','JetBrainsMono Nerd Font',Menlo,Monaco,'Courier New',monospace",
  "editor.fontLigatures": true,

  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  },
  "vscode-neovim.neovimExecutablePaths.linux": "/home/metsatron/.guix-extra-profiles/core/core/bin/nvim",

  "vim.enable": true,
  "vim.useSystemClipboard": true,
  "python.languageServer": "Default",
  "workbench.activityBar.location": "bottom"
}
