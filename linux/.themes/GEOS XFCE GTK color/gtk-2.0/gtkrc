            border          = { 0, 0, 0, 0 }
            stretch         = FALSE
            orientation     = VERTICAL
         	overlay_file    = "scroll_vertical_trough.png"
         	overlay_border  = { 1, 1, 1, 1 }
         	overlay_stretch = TRUE
        }
        image {
            function        = BOX
            recolorable     = TRUE
            detail          = "trough"
            file            = "scrollbar_overlay.png"
            border          = { 0, 0, 0, 0 }
            stretch         = FALSE
            orientation     = HORIZONTAL
         	overlay_file    = "scroll_horizontal_trough.png"
         	overlay_border  = { 1, 1, 1, 1 }
         	overlay_stretch = TRUE
        }
        image {
            function        = SLIDER
            recolorable     = TRUE
            state           = NORMAL
            file            = "scrollbar_horizontal.png"
            border          = { 1, 1, 1, 1 }
            stretch         = TRUE
