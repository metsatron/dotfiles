# pcc_bb_square_var
# xfwm theme created by pcc
# public domain

# This is a variation of my pcc_bb_square style.  Changes are the menu & pin
# icons and a minor edit to how the corner and side parts look when windows
# are rolled up

# Might want to uncomment the two border_color lines for some
# styles if the outline color is displayed strangely (like xfce-dusk)
#active_border_color=#000000
#inactive_border_color=#000000
button_offset=0
button_spacing=2
full_width_title=true
title_horizontal_offset=0
title_vertical_offset_active=0
title_vertical_offset_inactive=0
# looks better with text shadows off
title_shadow_active=false
title_shadow_inactive=false
