[Context]
shared=network;ipc;
sockets=x11;wayland;pulseaudio;fallback-x11;pcsc;cups;
devices=all;
features=devel;
filesystems=/etc/fonts:ro;/home/metsatron/.cache/fontconfig:ro;/usr/local/share/fonts:ro;xdg-run/speech-dispatcher:ro;/home/metsatron/.icons:ro;xdg-download;/home/metsatron/.local/share/fonts:ro;home;/var/cache/fontconfig:ro;/run/.heim_org.h5l.kcm-socket;/usr/share/fonts:ro;/home/metsatron/.config/fontconfig:ro;/home/metsatron/.dotfiles/linux/.flatpak/fontconfig:ro;
persistent=.zen;
unset-environment=FONTCONFIG_PATH;LD_PRELOAD;

[Session Bus Policy]
org.gtk.vfs.*=talk
org.mpris.MediaPlayer2.firefox.*=own
org.mozilla.zen.*=own
org.a11y.Bus=talk
org.freedesktop.FileManager1=talk

[System Bus Policy]
org.freedesktop.NetworkManager=talk

[Environment]
FONTCONFIG_PATH=
LD_PRELOAD=
FONTCONFIG_FILE=/home/metsatron/.dotfiles/linux/.flatpak/fontconfig/fonts.conf
DICPATH=/usr/share/hunspell
XCURSOR_SIZE=24
XCURSOR_THEME=behand
XCURSOR_PATH=/home/metsatron/.icons:/run/host/usr/local/share/icons:/run/host/usr/share/icons
