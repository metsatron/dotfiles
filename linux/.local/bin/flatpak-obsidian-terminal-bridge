#!/usr/bin/env bash
set -euo pipefail

APP_ID="md.obsidian.Obsidian"
VAULT_DIR="${OBSIDIAN_VAULT:-$HOME/HelmCortex}"
WRAPPER_PATH="${OBSIDIAN_HOST_ZSH:-$HOME/.local/bin/obsidian-host-zsh}"
REPO_WRAPPER_PATH="$HOME/DotCortex/linux/.local/bin/obsidian-host-zsh"
HOST_SPAWN_TARGET="${HOST_SPAWN_TARGET:-$HOME/.local/bin/host-spawn}"
GUIX_ZSH="${GUIX_ZSH:-$HOME/.guix-extra-profiles/core/core/bin/zsh}"
PYTHON_PATH="$VAULT_DIR/CORE/anaconda3/bin/python3"
PLUGIN_DATA="$VAULT_DIR/.obsidian/plugins/terminal/data.json"
WORKSPACE_JSON="$VAULT_DIR/.obsidian/workspace.json"

ensure_host_spawn() {
  [ -x "$HOST_SPAWN_TARGET" ] && return 0

  shopt -s nullglob
  local candidates=(
    "$HOME"/.local/share/flatpak/app/com.vscodium.codium/*/*/active/files/bin/host-spawn
    "$HOME"/.local/share/flatpak/app/com.vscodium.codium/*/*/*/files/bin/host-spawn
    /var/lib/flatpak/app/com.vscodium.codium/*/*/active/files/bin/host-spawn
    /var/lib/flatpak/app/com.vscodium.codium/*/*/*/files/bin/host-spawn
  )
  local candidate
  for candidate in "${candidates[@]}"; do
    [ -x "$candidate" ] || continue
    install -m 0755 "$candidate" "$HOST_SPAWN_TARGET"
    printf 'Installed host-spawn from %s\n' "$candidate"
    return 0
  done
  shopt -u nullglob

  printf 'WARN host-spawn not found; wrapper will fall back to flatpak-spawn --host\n' >&2
  return 0
}

ensure_wrapper() {
  [ -x "$WRAPPER_PATH" ] && return 0
  [ -x "$REPO_WRAPPER_PATH" ] || return 1

  mkdir -p "$(dirname "$WRAPPER_PATH")"
  ln -sfn "$REPO_WRAPPER_PATH" "$WRAPPER_PATH"
}

[ -d "$VAULT_DIR/.obsidian" ] || {
  printf 'skip Obsidian bridge: vault not found at %s\n' "$VAULT_DIR"
  exit 0
}

ensure_wrapper

[ -x "$WRAPPER_PATH" ] || {
  printf 'skip Obsidian bridge: wrapper missing at %s\n' "$WRAPPER_PATH" >&2
  exit 1
}

ensure_host_spawn

flatpak override --user --talk-name=org.freedesktop.Flatpak "$APP_ID"

[ -f "$PLUGIN_DATA" ] || {
  printf 'skip Obsidian bridge: terminal plugin config not found at %s\n' "$PLUGIN_DATA"
  exit 0
}

python3 - "$PLUGIN_DATA" "$WORKSPACE_JSON" "$WRAPPER_PATH" "$GUIX_ZSH" "$PYTHON_PATH" <<'PY'
import json
import pathlib
import sys

plugin_data = pathlib.Path(sys.argv[1])
workspace_json = pathlib.Path(sys.argv[2])
wrapper = sys.argv[3]
guix_zsh = sys.argv[4]
python_path = sys.argv[5]


def load_json(path: pathlib.Path):
    with path.open() as fh:
        return json.load(fh)


def dump_json(path: pathlib.Path, data):
    path.write_text(json.dumps(data, indent=2) + "\n")


desired_profile = {
    "args": [],
    "executable": wrapper,
    "name": "Guix zsh (host)",
    "platforms": {"darwin": False, "linux": True},
    "pythonExecutable": python_path,
    "restoreHistory": False,
    "rightClickAction": "copyPaste",
    "successExitCodes": ["0", "SIGINT", "SIGTERM"],
    "terminalOptions": {"documentOverride": None},
    "type": "integrated",
    "useWin32Conhost": False,
}

plugin = load_json(plugin_data)
profiles = plugin.setdefault("profiles", {})
profiles["dotcortexHostZsh"] = desired_profile

for key, profile in list(profiles.items()):
    if not isinstance(profile, dict):
        continue
    if key == "linuxIntegratedDefault":
        profiles[key] = desired_profile.copy()
        continue
    if profile.get("type") != "integrated":
        continue
    exe = profile.get("executable")
    name = profile.get("name")
    if exe in {guix_zsh, wrapper} or name in {"zsh", "Guix zsh (host)"}:
        updated = desired_profile.copy()
        updated["platforms"] = profile.get("platforms", desired_profile["platforms"])
        profiles[key] = updated

dump_json(plugin_data, plugin)

if workspace_json.exists():
    workspace = load_json(workspace_json)

    def visit(node):
        if isinstance(node, dict):
            term = node.get("terminal:terminal")
            if isinstance(term, dict):
              profile = term.get("profile")
              if isinstance(profile, dict):
                  exe = profile.get("executable")
                  name = profile.get("name")
                  if exe in {guix_zsh, wrapper} or name in {"zsh", "Guix zsh (host)"}:
                      term["profile"] = desired_profile.copy()
                      node["title"] = "Terminal: Guix zsh (host)"
            for value in node.values():
                visit(value)
        elif isinstance(node, list):
            for item in node:
                visit(item)

    visit(workspace)
    dump_json(workspace_json, workspace)

print(f"Updated {plugin_data}")
if workspace_json.exists():
    print(f"Updated {workspace_json}")
PY

printf 'Obsidian terminal bridge ready for %s\n' "$VAULT_DIR"
