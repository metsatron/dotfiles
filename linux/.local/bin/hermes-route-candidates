#!/usr/bin/env python3
import argparse
import json
from pathlib import Path
from typing import Any

USAGE_STATE_PATH = Path.home() / ".hermes" / "runtime" / "usage-state.json"

TASK_MATRIX: dict[str, list[dict[str, Any]]] = {
    "interface": [
        {"provider": "google", "model": "gemma-4-31b-it", "why": "friendly free interface lane"},
        {"provider": "nvidia", "model": "minimaxai/minimax-m2.7", "why": "user-preferred workhorse fallback"},
        {"provider": "nvidia", "model": "mistralai/mistral-large-3-675b-instruct-2512", "why": "general-purpose assistant fallback"},
    ],
    "coding": [
        {"provider": "nvidia", "model": "minimaxai/minimax-m2.7", "why": "default free workhorse coding lane"},
        {"provider": "nvidia", "model": "qwen/qwen3-coder-480b-a35b-instruct", "why": "top-tier coding specialist"},
        {"provider": "nvidia", "model": "mistralai/devstral-2-123b-instruct-2512", "why": "agentic SWE specialist"},
        {"provider": "google", "model": "gemma-4-31b-it", "why": "request-budget fallback"},
    ],
    "planning": [
        {"provider": "google", "model": "gemma-4-31b-it", "why": "free planning/interface lane"},
        {"provider": "nvidia", "model": "deepseek-ai/deepseek-v3.1-terminus", "why": "strong reasoning/planning fallback"},
        {"provider": "nvidia", "model": "moonshotai/kimi-k2-thinking", "why": "long-horizon planning fallback"},
    ],
    "research": [
        {"provider": "nvidia", "model": "moonshotai/kimi-k2-thinking", "why": "long-horizon research/tool lane"},
        {"provider": "nvidia", "model": "deepseek-ai/deepseek-v3.2", "why": "heavy reasoning research fallback"},
        {"provider": "google", "model": "gemma-4-31b-it", "why": "free synthesis fallback"},
    ],
    "reasoning": [
        {"provider": "nvidia", "model": "deepseek-ai/deepseek-v3.2", "why": "heavy reasoning primary"},
        {"provider": "nvidia", "model": "z-ai/glm-4.7", "why": "multilingual reasoning/tool use"},
        {"provider": "nvidia", "model": "deepseek-ai/deepseek-v3.1-terminus", "why": "hybrid think/non-think fallback"},
    ],
    "small": [
        {"provider": "openai-codex", "model": "gpt-5.4-mini", "why": "cheap disposable scripting lane"},
        {"provider": "nvidia", "model": "mistralai/magistral-small-2506", "why": "small efficient reasoning fallback"},
        {"provider": "nvidia", "model": "bytedance/seed-oss-36b-instruct", "why": "efficient long-context fallback"},
        {"provider": "google", "model": "gemma-3n-e4b-it", "why": "lightweight multimodal edge fallback"},
    ],
}

BURN_OVERRIDES: dict[str, list[dict[str, Any]]] = {
    "coding": [
        {"provider": "openai-codex", "model": "gpt-5.4", "why": "burn premium coding quota"},
        {"provider": "openai-codex", "model": "gpt-5.4-mini", "why": "burn small disposable quota"},
    ],
    "planning": [
        {"provider": "claude", "model": "claude-sonnet-4-6", "why": "high-quality writing/planning candidate via bridge/orchestrator"},
        {"provider": "openai-codex", "model": "gpt-5.4", "why": "burn premium planning quota when desired"},
    ],
    "research": [
        {"provider": "openai-codex", "model": "gpt-5.4", "why": "burn premium research/coding quota"},
    ],
}

CONSERVE_DEMOTIONS = {"openai-codex", "openrouter", "deepinfra", "claude"}


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Emit ordered Hermes routing candidates for a task class.")
    parser.add_argument("--task", choices=tuple(TASK_MATRIX.keys()), required=True)
    parser.add_argument("--mode", choices=("auto", "normal", "conserve", "burn"), default="auto")
    parser.add_argument("--usage-state", default=str(USAGE_STATE_PATH))
    parser.add_argument("--json", action="store_true", help="Emit machine-readable JSON")
    return parser.parse_args()


def load_usage_state(path: str) -> dict[str, Any]:
    p = Path(path)
    if not p.exists():
        return {"mode_recommendation": "normal", "providers": {}}
    try:
        return json.loads(p.read_text())
    except Exception:
        return {"mode_recommendation": "normal", "providers": {}}


def candidate_score(candidate: dict[str, Any], mode: str, usage_state: dict[str, Any]) -> tuple[int, dict[str, Any]]:
    providers = usage_state.get("providers") or {}
    pstate = providers.get(candidate["provider"], {}) if isinstance(providers, dict) else {}
    score = 0
    healthy = pstate.get("healthy", True)
    if healthy:
        score += 20
    else:
        score -= 40
    score += int(pstate.get("priority_score", 0) or 0)
    if mode == "burn" and candidate["provider"] == "openai-codex":
        score += 60
    if mode == "conserve" and candidate["provider"] in CONSERVE_DEMOTIONS:
        score -= 50
    if candidate["provider"] == "deepinfra":
        score -= 30
    detail = {
        "healthy": healthy,
        "provider_state": pstate,
    }
    return score, detail


def main() -> int:
    args = parse_args()
    usage_state = load_usage_state(args.usage_state)
    mode = usage_state.get("mode_recommendation", "normal") if args.mode == "auto" else args.mode
    candidates = list(TASK_MATRIX[args.task])
    if mode == "burn":
        candidates = BURN_OVERRIDES.get(args.task, []) + candidates
    scored = []
    seen = set()
    for candidate in candidates:
        key = (candidate["provider"], candidate["model"])
        if key in seen:
            continue
        seen.add(key)
        score, detail = candidate_score(candidate, mode, usage_state)
        scored.append({
            **candidate,
            "score": score,
            "healthy": detail["healthy"],
            "provider_state": detail["provider_state"],
        })
    scored.sort(key=lambda item: item["score"], reverse=True)
    payload = {
        "task": args.task,
        "mode": mode,
        "generated_from": args.usage_state,
        "candidates": scored,
    }
    if args.json:
        print(json.dumps(payload, indent=2))
    else:
        print(f"task={args.task} mode={mode}")
        for item in scored:
            state = "healthy" if item["healthy"] else "degraded"
            print(f"- {item['provider']} / {item['model']} [{item['score']}] ({state}) — {item['why']}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
