#!/usr/bin/env bash
# Moonlight launcher with DS4 deadzone

# [[file:../../../flatpak.org::*Moonlight launcher with DS4 deadzone][Moonlight launcher with DS4 deadzone:1]]
#!/usr/bin/env bash
set -euo pipefail

APP_ID="com.moonlight_stream.Moonlight"
SETUP="$HOME/.local/bin/flatpak-moonlight-ds4-setup"
DEADZONE_SCRIPT="$HOME/.local/bin/ds4-right-deadzone"
UDEV_INSTALLER="$HOME/.local/bin/ds4-udev-install"
UDEV_RULE="/etc/udev/rules.d/85-ds4-deadzone.rules"
FLATPAK_ENV=(
  --env=SDL_JOYSTICK_HIDAPI=0
  --env=SDL_JOYSTICK_HIDAPI_PS4=0
  --env=SDL_LINUX_JOYSTICK_DEADZONES=1
)
UDEV_BOOTSTRAPPED=0

if [ -x "$SETUP" ]; then
  "$SETUP"
else
  flatpak override --user --env=SDL_JOYSTICK_HIDAPI=0 "$APP_ID"
  flatpak override --user --env=SDL_JOYSTICK_HIDAPI_PS4=0 "$APP_ID"
  flatpak override --user --env=SDL_LINUX_JOYSTICK_DEADZONES=1 "$APP_ID"
fi

if [[ ! -r "$UDEV_RULE" && -x "$UDEV_INSTALLER" ]]; then
  echo "Installing DS4 udev rule for future launches..."
  if "$UDEV_INSTALLER"; then
    UDEV_BOOTSTRAPPED=1
  else
    echo "WARNING: could not install the DS4 udev rule automatically" >&2
  fi
fi

# Try running directly first (works if user has write access to /dev/input/event*
# via the input group or uaccess). Fall back to pkexec if that fails.
if [ "$(id -u)" -eq 0 ]; then
  "$DEADZONE_SCRIPT"
elif "$DEADZONE_SCRIPT" 2>/dev/null; then
  true
elif [ "$UDEV_BOOTSTRAPPED" -eq 1 ]; then
  echo "DS4 udev rule was just installed; skipping a second privilege prompt for this launch" >&2
elif command -v pkexec >/dev/null 2>&1; then
  pkexec "$DEADZONE_SCRIPT" || echo "WARNING: ds4-right-deadzone failed — drift may occur until a udev rule or direct device access is in place" >&2
else
  echo "WARNING: cannot elevate to run $DEADZONE_SCRIPT — drift may occur until a udev rule or direct device access is in place" >&2
fi

exec flatpak run "${FLATPAK_ENV[@]}" "$APP_ID"
# Moonlight launcher with DS4 deadzone:1 ends here
