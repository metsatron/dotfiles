#!/usr/bin/env bash
# Moonlight launcher with DS4 deadzone

# [[file:../../../flatpak.org::*Moonlight launcher with DS4 deadzone][Moonlight launcher with DS4 deadzone:1]]
#!/usr/bin/env bash
set -euo pipefail

APP_ID="com.moonlight_stream.Moonlight"
SETUP="$HOME/.local/bin/flatpak-moonlight-ds4-setup"
DEADZONE_SCRIPT="$HOME/.local/bin/ds4-right-deadzone"

if [ -x "$SETUP" ]; then
  "$SETUP"
else
  flatpak override --user --env=SDL_LINUX_JOYSTICK_DEADZONES=1 "$APP_ID"
fi

# Try running directly first (works if user has write access to /dev/input/event*
# via the input group or uaccess). Fall back to pkexec if that fails.
if [ "$(id -u)" -eq 0 ]; then
  "$DEADZONE_SCRIPT"
elif "$DEADZONE_SCRIPT" 2>/dev/null; then
  true
elif command -v pkexec >/dev/null 2>&1; then
  pkexec "$DEADZONE_SCRIPT" || echo "WARNING: ds4-right-deadzone failed — drift may occur" >&2
else
  echo "WARNING: cannot elevate to run $DEADZONE_SCRIPT — drift may occur" >&2
fi

exec flatpak run "$APP_ID"
# Moonlight launcher with DS4 deadzone:1 ends here
