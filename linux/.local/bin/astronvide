#!/usr/bin/env bash
# AstroNvide → Guix Neovim
# - Create a tiny wrapper so Neovide always uses your Guix nvim:

# [[file:../../../guix.org::*AstroNvide → Guix Neovim][AstroNvide → Guix Neovim:1]]
set -euo pipefail
NVIM="$HOME/.guix-extra-profiles/core/core/bin/nvim"
res="$(xrandr 2>/dev/null | awk '/\*/{print $1; exit}')"
export NVIM_APPNAME=astronvim
args=(--neovim-bin="$NVIM")
[ -n "${res:-}" ] && args+=(--size="$res")
exec neovide "${args[@]}" "$@"
# AstroNvide → Guix Neovim:1 ends here
