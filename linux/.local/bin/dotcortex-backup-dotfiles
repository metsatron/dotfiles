#!/usr/bin/env bash
# DotCortex backup - mirror DotCortex to a target

# [[file:../../../dotcortex.org::*DotCortex backup - mirror DotCortex to a target][DotCortex backup - mirror DotCortex to a target:1]]
#!/usr/bin/env bash
set -euo pipefail

SRC="$HOME/DotCortex"

if [[ ! -d "$SRC" ]]; then
  echo "Source repo not found at $SRC" >&2
  exit 1
fi

DEST_ROOT="${1-}"
if [[ -z "$DEST_ROOT" ]]; then
  echo "Usage: dotcortex-backup-dotfiles /path/to/backup-root" >&2
  exit 1
fi

DEST_ROOT="${DEST_ROOT%/}"
DEST="${DEST_ROOT}/DotCortex"

mkdir -p "$DEST_ROOT"

echo "Mirroring $SRC -> $DEST"
rsync -avh --delete "$SRC"/ "$DEST"/
# DotCortex backup - mirror DotCortex to a target:1 ends here
