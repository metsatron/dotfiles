#!/usr/bin/env bash
set -euo pipefail
apps=(
  org.garudalinux.firedragon
  one.ablaze.floorp
  org.wezfurlong.wezterm
)
for app in "${apps[@]}"; do
  echo ">> refreshing fontconfig cache inside $app"
  flatpak run --command=sh "$app" -lc \
    'fc-cache -fv $HOME/.local/share/fonts $HOME/.fonts /run/host/usr/local/share/fonts /run/host/usr/share/fonts'
done
echo "✅ done"
