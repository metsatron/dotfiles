#!/usr/bin/env bash
set -euo pipefail

HOST="${1:-}"
MOUNT_NAME="${2:-${1:-}}"

if [ -z "$HOST" ] || [ -z "$MOUNT_NAME" ]; then
  printf 'Usage: %s HOST [MOUNT_NAME]\n' "${0##*/}" >&2
  exit 2
fi

MNT="$HOME/mnt/$MOUNT_NAME"

is_mounted() {
  grep -F " $MNT " /proc/self/mountinfo >/dev/null 2>&1
}

report() {
  printf '%s\n' "$*" >&2
}

report_fail() {
  report "sshfs-emergency-unmount-home: $*"
  if command -v notify-send >/dev/null 2>&1; then
    notify-send "Unmount ${HOST} failed" "$*"
  fi
}

if ! is_mounted; then
  report "sshfs-emergency-unmount-home: ${MOUNT_NAME} is not mounted."
  if command -v notify-send >/dev/null 2>&1; then
    notify-send "Unmount ${HOST}" "${MOUNT_NAME} is not mounted."
  fi
  exit 0
fi

if ! (fusermount3 -uz "$MNT" || fusermount -uz "$MNT" || umount -l "$MNT") >/dev/null 2>&1; then
  report_fail "Could not unmount ${MOUNT_NAME}."
  exit 1
fi

report "sshfs-emergency-unmount-home: ${MOUNT_NAME} disconnected."

if command -v notify-send >/dev/null 2>&1; then
  notify-send "Unmount ${HOST}" "${MOUNT_NAME} was disconnected."
fi
