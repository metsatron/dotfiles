#!/usr/bin/env bash
# Goneovim → Guix Neovim
# - Create a tiny wrapper so Neovide always uses your Guix nvim:

# [[file:../../../guix.org::*Goneovim → Guix Neovim][Goneovim → Guix Neovim:1]]
set -euo pipefail
NVIM="$HOME/.guix-extra-profiles/core/core/bin/nvim"
if goneovim --help 2>&1 | grep -q -- '--nvimpath'; then
  exec goneovim --nvimpath "$NVIM" --maximized "$@"
else
  exec goneovim --neovim-bin "$NVIM" --maximized "$@"
fi
# Goneovim → Guix Neovim:1 ends here
