#!/usr/bin/env bash
# Moonlight SDL joystick deadzone override
# Moonlight's Flatpak must be told to honour kernel deadzones via SDL.
# This is a one-time =flatpak override= — run it once, or let =flatpak-perms-apply= handle it.

# Two SDL layers are needed:
# - =SDL_JOYSTICK_HIDAPI_PS4=0= forces SDL to use the evdev driver for the DS4
#   rather than HIDAPI (which reads =/dev/hidraw*= and ignores kernel flat values entirely).
# - =SDL_LINUX_JOYSTICK_DEADZONES=1= tells the evdev driver to respect the =ABS_FLAT=
#   values set by =ds4-right-deadzone=.

# Without disabling HIDAPI, =evdev-joystick --deadzone= has no effect because SDL
# never touches the evdev axis metadata.


# [[file:../../../flatpak.org::*Moonlight SDL joystick deadzone override][Moonlight SDL joystick deadzone override:1]]
#!/usr/bin/env bash
set -euo pipefail

APP_ID="com.moonlight_stream.Moonlight"

echo "Disabling SDL HIDAPI globally (forces evdev path where flat values apply)"
flatpak override --user --env=SDL_JOYSTICK_HIDAPI=0 "$APP_ID"
flatpak override --user --env=SDL_JOYSTICK_HIDAPI_PS4=0 "$APP_ID"

echo "Enabling SDL_LINUX_JOYSTICK_DEADZONES for $APP_ID"
flatpak override --user --env=SDL_LINUX_JOYSTICK_DEADZONES=1 "$APP_ID"

echo "Done."
echo
echo "Run ds4-right-deadzone (with sudo) before launching Moonlight:"
echo "  sudo ~/.local/bin/ds4-right-deadzone"
echo "  flatpak run $APP_ID"
# Moonlight SDL joystick deadzone override:1 ends here
