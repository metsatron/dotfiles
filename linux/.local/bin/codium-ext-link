#!/usr/bin/env bash
#!/usr/bin/env bash
set -euo pipefail

APPID="com.vscodium.codium"
HOST_EXT="$HOME/.vscode-oss/extensions"
SBX_BASE="$HOME/.var/app/$APPID/data"
SBX_VSC="$SBX_BASE/VSCodium/extensions"
SBX_COD="$SBX_BASE/codium/extensions"

link_one() {
  local target="$1"
  if [ -L "$target" ]; then
    if [ "$(readlink -f "$target")" = "$HOST_EXT" ]; then
      echo "Already linked: $target -> $HOST_EXT"
      return 0
    else
      echo "Different symlink at $target, refusing to overwrite." >&2
      return 1
    fi
  elif [ -e "$target" ]; then
    echo "Real dir/file exists at $target, refusing to overwrite." >&2
    return 1
  else
    mkdir -p "$(dirname "$target")"
    ln -s "$HOST_EXT" "$target"
    echo "Linked: $target -> $HOST_EXT"
  fi
}

[ -d "$HOST_EXT" ] || { echo "Host extensions not found: $HOST_EXT" >&2; exit 1; }
link_one "$SBX_VSC"
link_one "$SBX_COD"
