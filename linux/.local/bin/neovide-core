#!/usr/bin/env bash
# Neovide → Guix Neovim
# - Create a tiny wrapper so Neovide always uses your Guix nvim:

# [[file:../../../guix.org::*Neovide → Guix Neovim][Neovide → Guix Neovim:1]]
set -euo pipefail
NVIM="$HOME/.guix-extra-profiles/core/core/bin/nvim"
exec neovide --neovim-bin="$NVIM" "$@"
# Neovide → Guix Neovim:1 ends here
