#!/usr/bin/env bash
set -euo pipefail

GUIX_ZSH="${GUIX_ZSH:-$HOME/.guix-extra-profiles/core/core/bin/zsh}"
HOST_SPAWN="${HOST_SPAWN:-$HOME/.local/bin/host-spawn}"

export HOME="${HOME:?}"
export USER="${USER:-metsatron}"
export LOGNAME="${LOGNAME:-$USER}"
export SHELL="$GUIX_ZSH"
export TERM="${TERM:-xterm-256color}"
export LANG="${LANG:-C.UTF-8}"
export LC_ALL="${LC_ALL:-}"
export COLORTERM="${COLORTERM:-truecolor}"

unset LD_PRELOAD

if [ -z "${FLATPAK_ID:-${container:-}}" ]; then
  exec "$GUIX_ZSH" -i "$@"
fi

if [ -x "$HOST_SPAWN" ]; then
  exec "$HOST_SPAWN" \
    -pty \
    -cwd "${PWD:-$HOME}" \
    env \
      -u LD_PRELOAD \
      -u FLATPAK_ID \
      -u container \
      HOME="$HOME" \
      USER="$USER" \
      LOGNAME="$LOGNAME" \
      SHELL="$SHELL" \
      TERM="$TERM" \
      LANG="$LANG" \
      LC_ALL="$LC_ALL" \
      COLORTERM="$COLORTERM" \
      "$GUIX_ZSH" -i "$@"
fi

exec /usr/bin/flatpak-spawn --host \
  env \
    -u LD_PRELOAD \
    -u FLATPAK_ID \
    -u container \
    HOME="$HOME" \
    USER="$USER" \
    LOGNAME="$LOGNAME" \
    SHELL="$SHELL" \
    TERM="$TERM" \
    LANG="$LANG" \
    LC_ALL="$LC_ALL" \
    COLORTERM="$COLORTERM" \
    "$GUIX_ZSH" -i "$@"
