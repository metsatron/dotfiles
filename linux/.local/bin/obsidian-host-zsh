#!/usr/bin/env bash
set -euo pipefail

GUIX_ZSH="${GUIX_ZSH:-$HOME/.guix-extra-profiles/core/core/bin/zsh}"
HOST_SPAWN="${HOST_SPAWN:-$HOME/.local/bin/host-spawn}"
HOST_ENV="HOME,USER,LOGNAME,SHELL,TERM,LANG,LC_ALL,COLORTERM,DISPLAY,WAYLAND_DISPLAY,XAUTHORITY,DBUS_SESSION_BUS_ADDRESS,XDG_RUNTIME_DIR,SSH_AUTH_SOCK"

export HOME="${HOME:?}"
export USER="${USER:-metsatron}"
export LOGNAME="${LOGNAME:-$USER}"
export SHELL="$GUIX_ZSH"
export TERM="${TERM:-xterm-256color}"
export LANG="${LANG:-C.UTF-8}"
export LC_ALL="${LC_ALL:-}"
export COLORTERM="${COLORTERM:-truecolor}"
unset LD_PRELOAD

if [ -z "${FLATPAK_ID:-${container:-}}" ]; then
  exec "$GUIX_ZSH" -i "$@"
fi

if [ -x "$HOST_SPAWN" ]; then
  exec "$HOST_SPAWN" \
    -pty \
    -cwd "${PWD:-$HOME}" \
    -env "$HOST_ENV" \
    "$GUIX_ZSH" -i "$@"
fi

exec /usr/bin/flatpak-spawn --host "$GUIX_ZSH" -i "$@"
