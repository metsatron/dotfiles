#!/usr/bin/env bash
#!/usr/bin/env bash
set -euo pipefail

APPID="com.vscodium.codium"

cfg_candidates=("$HOME/.config/VSCodium" "$HOME/.config/Code - OSS" "$HOME/.config/Code")
CONFIG_ROOT=""
for d in "${cfg_candidates[@]}"; do [ -d "$d" ] && CONFIG_ROOT="$d" && break; done
[ -n "$CONFIG_ROOT" ] || { echo "No config root found." >&2; exit 1; }

exec flatpak run \
  --env=PATH="$HOME/.guix-extra-profiles/core/core/bin:/usr/bin:/app/bin" \
  "$APPID" \
  --user-data-dir="$CONFIG_ROOT" \
  --extensions-dir="$HOME/.vscode-oss/extensions" \
  "$@"
