#!/usr/bin/env bash
# ~/.local/bin/codium-host
#!/usr/bin/env bash
set -euo pipefail

APPID="com.vscodium.codium"

cfg_candidates=("$HOME/.config/VSCodium" "$HOME/.config/Code - OSS" "$HOME/.config/Code")
CONFIG_ROOT=""
for d in "${cfg_candidates[@]}"; do [ -d "$d" ] && CONFIG_ROOT="$d" && break; done
[ -n "$CONFIG_ROOT" ] || { echo "No config root found." >&2; exit 1; }

# Dynamic, no hardcoding. Allow override via env if you ever want it.
EXT_DIR="${VSCODE_EXTENSIONS_DIR:-$HOME/.vscode-oss/extensions}"

extra_flags=()
# Add X11 only if not already present in argv.json and not passed on CLI
argv_json="$CONFIG_ROOT/argv.json"
if [ ! -f "$argv_json" ] || ! grep -q '"ozone-platform"' "$argv_json"; then
  if ! printf '%s\n' "$@" | grep -q -- '--ozone-platform='; then
    extra_flags+=(--ozone-platform=x11)
  fi
fi

# Only clear LD_PRELOAD if it contains nocsd, otherwise leave your env alone
extra_env=(
  --env=PATH="$HOME/.guix-extra-profiles/core/core/bin:/usr/bin:/app/bin"
)
if [ "${LD_PRELOAD-}" != "" ] && printf '%s' "$LD_PRELOAD" | grep -q 'libgtk3-nocsd'; then
  extra_env+=(--env=LD_PRELOAD=)
fi

# Optional env scrubs if you ever see WebView crashes again. Leave commented unless needed.
# ENV_EXTRA=(
#   --env=GIO_MODULE_DIR=
#   --env=GIO_EXTRA_MODULES=
#   --env=GI_TYPELIB_PATH=
#   --env=LD_LIBRARY_PATH=
#   --env=GTK_PATH=
#   --env=GTK_IM_MODULE=
#   --env=QT_QPA_PLATFORMTHEME=
#   --env=QT_PLUGIN_PATH=
#   --env=QT_STYLE_OVERRIDE=
#   --env=XDG_DATA_DIRS=/usr/share:/app/share
#   --env=XDG_CONFIG_DIRS=/etc/xdg
# )

exec flatpak run \
  "${extra_env[@]}" \
  "$APPID" \
  --user-data-dir="$CONFIG_ROOT" \
  --extensions-dir="$EXT_DIR" \
  "${extra_flags[@]}" \
  "$@"
