#!/usr/bin/env bash
# Obsidian launcher wrapper

# [[file:../../../flatpak.org::*Obsidian launcher wrapper][Obsidian launcher wrapper:1]]
set -euo pipefail

APP_ID="md.obsidian.Obsidian"

# The Flatpak export is noisy in agent sessions on systems without a system bus
# and when host AppMenu modules leak into the sandbox. Preserve stdout and all
# non-matching stderr so CLI results and real failures remain visible.
NOISE_RE='(ERROR:dbus/bus\.cc:[0-9]+\].*Failed to connect to the bus|socket /run/dbus/system_bus_socket: No such file or directory|Gtk-Message: .*Failed to load module "appmenu-gtk-module")'

if [ "${OBSIDIAN_RAW_STDERR:-0}" = 1 ]; then
  exec env \
    -u GTK_MODULES \
    -u LD_PRELOAD \
    flatpak run \
      --env=GTK_MODULES= \
      --env=LD_PRELOAD= \
      "$APP_ID" \
      "$@"
fi

exec env \
  -u GTK_MODULES \
  -u LD_PRELOAD \
  flatpak run \
    --env=GTK_MODULES= \
    --env=LD_PRELOAD= \
    "$APP_ID" \
    "$@" \
    2> >(grep -v -E "$NOISE_RE" >&2 || true)
# Obsidian launcher wrapper:1 ends here
