#!/usr/bin/env bash
#!/usr/bin/env bash
set -euo pipefail

EXTROOT="$HOME/.vscode-oss/extensions"
PKG="metsatron.laincore-theme"
VER="0.0.1"
EXTDIR="$EXTROOT/$PKG-$VER"
THEMES="$EXTDIR/themes"

# Prefer repo source; fall back to the user path if needed.
SRC_REPO="$HOME/.dotfiles/all/.config/VSCodium/User/laincore-theme.json"
SRC_USER="$HOME/.config/VSCodium/User/laincore-theme.json"
SRC=""
if [ -f "$SRC_REPO" ]; then SRC="$SRC_REPO"
elif [ -f "$SRC_USER" ]; then SRC="$SRC_USER"
else
  echo "Theme JSON not found at $SRC_REPO or $SRC_USER" >&2
  exit 1
fi

mkdir -p "$THEMES"

# Symlink into extension
ln -sfn "$SRC" "$THEMES/laincore-color-theme.json"

# Minimal package.json
cat > "$EXTDIR/package.json" <<'JSON'
{
  "name": "laincore-theme",
  "displayName": "LainCore",
  "publisher": "metsatron",
  "version": "0.0.1",
  "engines": { "vscode": "^1.60.0" },
  "categories": ["Themes"],
  "contributes": {
    "themes": [
      { "label": "LainCore", "uiTheme": "vs-dark", "path": "./themes/laincore-color-theme.json" }
    ]
  }
}
JSON

echo "LainCore theme extension ready at: $EXTDIR"
echo "→ JSON source: $SRC"
