#!/usr/bin/env bash
set -euo pipefail
CORE="$HOME/.config/emacs"  # Doom core
# Prefer Emacs 29+'s --init-directory (cleanest)
if emacs --help 2>/dev/null | grep -q -- '--init-directory'; then
  exec emacs --init-directory "$CORE" "$@"
else
  # Fallback for older Emacs: sandbox HOME so ~/.emacs.d -> Doom core
  HOME_TMP="$HOME/.emacs.profiles/home-doom-default"
  mkdir -p "$HOME_TMP"
  ln -sfn "$CORE" "$HOME_TMP/.emacs.d"
  exec env HOME="$HOME_TMP" emacs "$@"
fi
