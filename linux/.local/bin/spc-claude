#!/usr/bin/env bash
# IMPORTANT: no -u (breaks Guix profile init)
set -eo pipefail

GUIX_PROFILE="$HOME/.guix-extra-profiles/core/core"
if [ -r "$GUIX_PROFILE/etc/profile" ]; then
  # shellcheck disable=SC1090
  . "$GUIX_PROFILE/etc/profile"
fi

# Extra safety: make sure Emacs can see Guix site-lisp & libs even if profile sourcing is partial.
export EMACSLOADPATH="$GUIX_PROFILE/share/emacs/site-lisp${EMACSLOADPATH:+:$EMACSLOADPATH}"
export LD_LIBRARY_PATH="$GUIX_PROFILE/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"

NAME="claude"
SPC_DIR="$HOME/.spacemacs.d.claude"
CORE="$HOME/.emacs.d.spacemacs"
PROFILES_DIR="$HOME/.emacs.profiles"

EMV="$(emacs --batch --eval '(princ emacs-major-version)' 2>/dev/null || echo 27)"

if [ "$EMV" -ge 29 ] && emacs --help 2>&1 | grep -q -- '--init-directory'; then
  exec env SPACEMACSDIR="$SPC_DIR" emacs --init-directory "$CORE" "$@"
else
  HOME_TMP="$PROFILES_DIR/home-spacemacs-$NAME"
  mkdir -p "$HOME_TMP"
  ln -sfn "$CORE"    "$HOME_TMP/.emacs.d"
  ln -sfn "$SPC_DIR" "$HOME_TMP/.spacemacs.d"
  exec env HOME="$HOME_TMP" emacs "$@"
fi
