#!/usr/bin/env bash
# Moonlight DS4 both-sticks deadzone
# Apply a kernel-level deadzone to both DS4 sticks
# (axes 0=ABS_X, 1=ABS_Y for left; 3=ABS_RX, 4=ABS_RY for right)
# so Moonlight does not see drift at rest.

# Moonlight uses SDL2 for gamepad input. The kernel flatness alone is not
# enough — SDL must also be told to honour it via
# =SDL_LINUX_JOYSTICK_DEADZONES=1=. That override is applied once by
# =flatpak override= (see below) and persists across launches.


# [[file:../../../flatpak.org::*Moonlight DS4 both-sticks deadzone][Moonlight DS4 both-sticks deadzone:1]]
# ~/.local/bin/ds4-right-deadzone
#!/usr/bin/env bash
set -euo pipefail

# DS4 both-stick deadzone. Sticks need independent values because the right stick
# bleeds into ABS_Y (left stick Y) by ~25 counts when rotated to the NW quadrant.
# DS4_DEADZONE_L (left):  45 — covers 25-count ADC bleed with 20 counts headroom
# DS4_DEADZONE_R (right): 35 — covers observed right-stick drift
# Override either via env: DS4_DEADZONE_L=50 moonlight-ds4-right-deadzone
DEADZONE_L="${DS4_DEADZONE_L:-45}"
DEADZONE_R="${DS4_DEADZONE_R:-35}"
WAIT_SECS=20

matches_target_name() {
  local name="$1"
  [[ "$name" == "Sony Interactive Entertainment Wireless Controller" ]] \
    || [[ "$name" == "Wireless Controller" ]]
}

find_controller_event() {
  local evsys name_file name dev
  for evsys in /sys/class/input/event*; do
    [[ -e "$evsys" ]] || continue
    dev="/dev/input/${evsys##*/}"
    name_file="$evsys/device/name"
    [[ -r "$name_file" ]] || continue
    name="$(<"$name_file")"
    matches_target_name "$name" || continue
    if evdev-joystick --showcal "$dev" >/dev/null 2>&1; then
      printf '%s\n' "$dev"
      return 0
    fi
  done
  return 1
}

main() {
  command -v evdev-joystick >/dev/null 2>&1 || {
    echo "Missing required command: evdev-joystick (apt install joystick)" >&2
    exit 1
  }

  local dev=""
  for ((i=0; i<WAIT_SECS; i++)); do
    if dev="$(find_controller_event)"; then
      break
    fi
    sleep 1
  done

  if [[ -z "$dev" ]]; then
    echo "DS4 controller not found after ${WAIT_SECS}s" >&2
    exit 1
  fi

  # ABS_X = axis 0, ABS_Y = axis 1 (left stick — higher deadzone absorbs ADC bleed from right stick)
  evdev-joystick --evdev "$dev" --axis 0 --deadzone "$DEADZONE_L"
  evdev-joystick --evdev "$dev" --axis 1 --deadzone "$DEADZONE_L"
  # ABS_RX = axis 3, ABS_RY = axis 4 (right stick)
  evdev-joystick --evdev "$dev" --axis 3 --deadzone "$DEADZONE_R"
  evdev-joystick --evdev "$dev" --axis 4 --deadzone "$DEADZONE_R"

  echo "Applied left-stick deadzone ${DEADZONE_L}, right-stick deadzone ${DEADZONE_R} to ${dev}"
  evdev-joystick --showcal "$dev"
}

main "$@"
# Moonlight DS4 both-sticks deadzone:1 ends here
