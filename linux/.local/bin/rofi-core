#!/usr/bin/env bash
# Rofi core wrapper (single entry point)

# [[file:../../../guix.org::*Rofi core wrapper (single entry point)][Rofi core wrapper (single entry point):1]]
set -euo pipefail

PROFILE="$HOME/.guix-extra-profiles/core/core"

# Load core Guix profile (PATH, XDG_DATA_DIRS, etc.) if present
if [ -r "$PROFILE/etc/profile" ]; then
  # shellcheck source=/dev/null
  . "$PROFILE/etc/profile"
fi

# Defer everything else to rofi, untouched
exec "$PROFILE/bin/rofi" "$@"
# Rofi core wrapper (single entry point):1 ends here
