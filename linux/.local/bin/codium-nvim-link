#!/usr/bin/env bash
#!/usr/bin/env bash
set -euo pipefail

APPID="com.vscodium.codium"
SBX_CFG="$HOME/.var/app/$APPID/config/nvim"
REPO_CFG="$HOME/DotCortex/all/.config/nvim"

if [ ! -d "$REPO_CFG" ]; then
  echo "Repo nvim not found: $REPO_CFG" >&2
  exit 1
fi

if [ -L "$SBX_CFG" ]; then
  # already a symlink
  tgt="$(readlink -f "$SBX_CFG")"
  if [ "$tgt" = "$REPO_CFG" ]; then
    echo "Already linked: $SBX_CFG -> $REPO_CFG"
    exit 0
  else
    echo "Different symlink at $SBX_CFG, refusing to overwrite." >&2
    exit 1
  fi
elif [ -e "$SBX_CFG" ]; then
  # real dir or file exists, back it up once
  ts=$(date +%Y%m%d-%H%M%S)
  echo "Backing up $SBX_CFG -> ${SBX_CFG}.bak.$ts"
  mv "$SBX_CFG" "${SBX_CFG}.bak.$ts"
fi

mkdir -p "$(dirname "$SBX_CFG")"
ln -sT "$REPO_CFG" "$SBX_CFG"
echo "Linked: $SBX_CFG -> $REPO_CFG"
