#!/usr/bin/env bash
# [[file:../../../flatpak.org::*GitHub release-backed Flatpak bundles][GitHub release-backed Flatpak bundles:2]]
#!/usr/bin/env bash
set -euo pipefail

REL_MAN="${HOME}/DotCortex/linux/.flatpak/manifest/releases.ssv"
[ -f "$REL_MAN" ] || exit 0

CLEAN_ENV=(env -i HOME="$HOME" PATH="/usr/sbin:/usr/bin:/bin:${HOME}/.local/bin"
  LANG="${LANG:-C.UTF-8}" LC_ALL="${LC_ALL:-C.UTF-8}"
  TERM="${TERM:-xterm-256color}"
  XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
  DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-}")

gh_latest_json() {
  local repo="$1" url="https://api.github.com/repos/${repo}/releases/latest"
  if [ -n "${GH_TOKEN:-}" ]; then
    curl -fsSL -H "Authorization: Bearer $GH_TOKEN" "$url"
  else
    curl -fsSL "$url"
  fi
}

installed_version() {
  local app_id="$1" scope="$2"
  if [ "$scope" = user ]; then
    { "${CLEAN_ENV[@]}" flatpak --user info "$app_id" 2>/dev/null | awk -F': *' '/^[[:space:]]*Version:/ {print $2}'; } || true
  else
    { "${CLEAN_ENV[@]}" flatpak --system info "$app_id" 2>/dev/null | awk -F': *' '/^[[:space:]]*Version:/ {print $2}'; } || true
  fi
}

echo "[release bundles]"
awk '$0!~/^#/ && NF>=4 {print $1 "\t" $2 "\t" $3 "\t" $4}' "$REL_MAN" \
  | while IFS=$'\t' read -r repo app_id asset_name scope; do
      have="$(installed_version "$app_id" "$scope")"
      if [ -z "$have" ]; then
        echo "  + $app_id $scope (missing, release bundle from $repo)"
        continue
      fi
      json="$(gh_latest_json "$repo")"
      latest_tag="$(jq -r '.tag_name' <<<"$json")"
      latest_ver="$(sed -E 's/^v//' <<<"$latest_tag")"
      resolved_asset_name=""
      while IFS=$'\t' read -r asset_entry_name _asset_entry_url _asset_entry_digest; do
        case "$asset_entry_name" in
          $asset_name)
            resolved_asset_name="$asset_entry_name"
            break
            ;;
        esac
      done < <(jq -r '.assets[] | [.name, .browser_download_url, (.digest // "")] | @tsv' <<<"$json")
      if [ -z "$resolved_asset_name" ]; then
        echo "  ? $app_id $scope (no release asset matching $asset_name in $repo)"
        continue
      fi
      newest="$(printf '%s\n%s\n' "$have" "$latest_ver" | sort -V | tail -n1)"
      if [ "$newest" = "$have" ]; then
        echo "  = $app_id $scope ($have, asset $resolved_asset_name)"
      else
        echo "  ~ $app_id $scope ($have -> $latest_ver, asset $resolved_asset_name)"
      fi
    done
# GitHub release-backed Flatpak bundles:2 ends here
