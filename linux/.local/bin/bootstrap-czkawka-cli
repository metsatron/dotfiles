#!/usr/bin/env bash
set -Eeuo pipefail

# Installs rustup (user-local), updates the toolchain, and builds czkawka_cli.
# No sudo needed; everything goes under ~/.cargo and ~/.rustup

die(){ echo "ERROR: $*" >&2; exit 1; }
have(){ command -v "$1" >/dev/null 2>&1; }

echo "[*] Bootstrapping czkawka_cli (user-local)…"
if ! have curl && ! have wget; then
  die "Need curl or wget to fetch rustup."
fi

if ! command -v rustup >/dev/null 2>&1; then
  echo "[*] Installing rustup..."
  if command -v curl >/dev/null 2>&1; then
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
  else
    wget -qO- https://sh.rustup.rs | sh -s -- -y
  fi
  # Load cargo into this shell:
  export PATH="$HOME/.cargo/bin:$PATH"
fi

echo "[*] Updating toolchain…"
rustup self update || true
rustup update

echo "[*] Installing/Updating czkawka_cli… (this compiles; first run can be long)"
# --force ensures upgrade if it’s already present
cargo install --force czkawka_cli

echo "[✓] Done. Ensure PATH has ~/.cargo/bin (add to your shell rc if needed)."
command -v czkawka_cli && czkawka_cli --version || true
