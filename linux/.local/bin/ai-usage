    key: str
    label: str
    kind: str
    codexbar_provider: str | None = None
    codexbar_args: tuple[str, ...] = ()
    fuelcheck_provider: str | None = None
    fuelcheck_args: tuple[str, ...] = ()
    note: str = ""


