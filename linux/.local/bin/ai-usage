def tc(hex_color: str) -> str:
    hex_color = hex_color.lstrip("#")
    r = int(hex_color[0:2], 16)
    g = int(hex_color[2:4], 16)
    b = int(hex_color[4:6], 16)
    return f"\033[38;2;{r};{g};{b}m"


R = "\033[0m"
DIM = "\033[2m"
B = "\033[1m"
GR = tc("#4caf50")   # base0B
YL = tc("#b58900")   # base0A
RD = tc("#dc322f")   # base08
CY = tc("#15b8cf")   # base0C
FGY = tc("#cbcbcb")  # base04
GY = tc("#6a6a6a")   # base03
WH = tc("#ffffff")   # base07

NF = {
    "check": "\uf058",
    "cross": "\uf057",
    "clock": "\uf017",
    "bolt": "\uf0e7",
    "github": "\uf09b",
    "brain": "\uf5dc",
    "google": "\uf1a0",
    "server": "\uf233",
    "link": "\uf0c1",
    "cursor": "\uf245",
    "copilot": "\ue70a",
    "coin": "\uf155",
    "user": "\uf007",
    "hourglass": "\uf254",
}

W = 74


def terminal_width() -> int:
    try:
        return max(40, min(shutil.get_terminal_size((W, 20)).columns, 140))
    except OSError:
        return W


@dataclass(frozen=True)
