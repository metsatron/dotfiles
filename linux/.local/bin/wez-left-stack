# ~/.dotfiles/linux/.local/bin/wez-left-stack
#!/usr/bin/env sh
set -eu

# layout flags
export WEZ_LEFT_STACK=1
export VSPLIT="${VSPLIT:-70}"
export HSPLIT="${HSPLIT:-26}"

# sanitize env so Flatpak uses host GLib modules, not Guix-injected ones
unset GIO_EXTRA_MODULES
unset GI_TYPELIB_PATH
unset LD_LIBRARY_PATH

# silence the XDG_DATA_DIRS warning and expose Flatpak exports
XDG_DATA_DIRS="${XDG_DATA_DIRS:-/usr/local/share:/usr/share}"
XDG_DATA_DIRS="/var/lib/flatpak/exports/share:$HOME/.local/share/flatpak/exports/share:$XDG_DATA_DIRS"
export XDG_DATA_DIRS

# run WezTerm Flatpak
exec /usr/bin/flatpak run --branch=stable --arch=x86_64 org.wezfurlong.wezterm
