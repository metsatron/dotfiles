#!/usr/bin/env bash
set -euo pipefail

findish() {
  # translate a common subset to fd
  local depth=      # -d N
  local type=       # -t f|d
  local name=       # -g pattern
  local iname=      # -i + -g pattern
  local print0=     # -0
  local exclude=()  # -E path (prune)
  local path="."    # search root
  local exec_mode=  # -x / -X
  local exec_cmd=()

  # parse: findish [PATH] [-maxdepth N] (-type f|d) (-name PAT) (-iname PAT)
  #        [-print0] [-prune PATH ...] [-exec cmd {} \;] [-exec cmd {} +]
  while [[ $# -gt 0 ]]; do
    case "$1" in
      .|/*) path="$1"; shift ;;
      -maxdepth) depth="$2"; shift 2 ;;
      -type)     type="$2"; shift 2 ;;
      -name)     name="$2"; shift 2 ;;
      -iname)    iname="$2"; shift 2 ;;
      -print0)   print0=1; shift ;;
      -prune)    exclude+=("$2"); shift 2 ;;
      -path)     # treat as exclude with glob
                 exclude+=("$2"); shift 2 ;;
      -exec)
        # collect until \; or +
        shift
        exec_cmd=()
        while [[ $# -gt 0 ]]; do
          if [[ "$1" == ";" ]]; then exec_mode="-x"; shift; break; fi
          if [[ "$1" == "+" ]]; then exec_mode="-X"; shift; break; fi
          exec_cmd+=("$1"); shift
        done
        ;;
      *) break ;;
    esac
  done

  local args=()

  [[ -n "$depth" ]] && args+=(-d "$depth")
  case "$type" in f) args+=(-t f);; d) args+=(-t d);; esac

  # pattern handling: use glob mode for -name/-iname
  if [[ -n "$name" ]]; then
    args+=(-g "$name")
  fi
  if [[ -n "$iname" ]]; then
    args+=(-i -g "$iname")
  fi

  # excludes (prune-ish)
  for e in "${exclude[@]}"; do
    args+=(-E "$e")
  done

  [[ -n "$print0" ]] && args+=(-0)

  # default path if not passed
  args+=("$path")

  # exec mapping
  if [[ -n "$exec_mode" ]]; then
    # replace '{}' with placeholder {}
    # fd automatically appends matches at the end if we use -x/-X after '--'
    # emulate "cmd {} ..." by putting '{}' where appropriate
    # We'll build: fd ... -x sh -c 'cmd "$@"' _ {} ...
    local script=()
    for token in "${exec_cmd[@]}"; do
      if [[ "$token" == "{}" ]]; then
        script+=("\$@")
      else
        script+=("$(printf '%q' "$token")")
      fi
    done
    # execute via sh -c to preserve ordering
    fd "${args[@]}" "$exec_mode" sh -c "${script[*]}" _ {}
  else
    fd "${args[@]}"
  fi
}
