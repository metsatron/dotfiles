#!/usr/bin/env bash
set -Eeuo pipefail
tmp=$(mktemp)
sudo npm -g ls --depth=0 --parseable 2>/dev/null \
 | awk -F/ 'NR>1{print $NF}' \
 | sed '/^npm$/d;/^corepack$/d' \
 | sort -u > "$tmp" || true

if [ ! -s "$tmp" ]; then
  echo "[i] No root-scoped npm globals to migrate."
  exit 0
fi

echo "[i] Migrating these packages from root -> user:"
cat "$tmp" | sed 's/^/   - /'

# install under user toolchain
xargs -r -n1 npm -g install < "$tmp"

# remove from root toolchain
sudo xargs -r -n1 npm -g rm < "$tmp"

rm -f "$tmp"
echo "[✓] Migration complete."
