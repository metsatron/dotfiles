#!/usr/bin/env bash
# [[file:../../../flatpak.org::*Managed udev hotplug rule][Managed udev hotplug rule:2]]
#!/usr/bin/env bash
set -euo pipefail

RULE_NAME="85-ds4-deadzone.rules"
OWNER_USER="${SUDO_USER:-${USER:-$(id -un)}}"
OWNER_HOME="$(getent passwd "$OWNER_USER" | cut -d: -f6)"
RULE_SRC="$OWNER_HOME/.local/share/udev/rules.d/$RULE_NAME"
RULE_DEST="/etc/udev/rules.d/$RULE_NAME"
APPLIER="$OWNER_HOME/.local/bin/ds4-right-deadzone"

run_root() {
  if [[ "$(id -u)" -eq 0 ]]; then
    "$@"
  else
    sudo "$@"
  fi
}

command -v udevadm >/dev/null 2>&1 || {
  echo "Missing required command: udevadm" >&2
  exit 1
}

[[ -r "$RULE_SRC" ]] || {
  echo "Missing managed rule source: $RULE_SRC" >&2
  echo "Tangle and stow DotCortex first so the rule lands under ~/.local/share." >&2
  exit 1
}

run_root install -d -m 0755 /etc/udev/rules.d
run_root install -m 0644 "$RULE_SRC" "$RULE_DEST"
run_root udevadm control --reload-rules

echo "Installed $RULE_DEST from $RULE_SRC"

if [[ -x "$APPLIER" ]]; then
  if run_root "$APPLIER"; then
    echo "Applied DS4 deadzone immediately for the currently connected controller."
  else
    echo "Rule installed; replug the DS4 or run $APPLIER after connecting it." >&2
  fi
else
  echo "Rule installed; replug the DS4 after connecting DotCortex's ~/.local/bin into place." >&2
fi
# Managed udev hotplug rule:2 ends here
