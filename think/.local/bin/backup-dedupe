#!/usr/bin/env bash
set -Eeuo pipefail

# === CONFIG ===
NAME="dedupe"
LOG="/tmp/backup_${NAME}_$(date +%Y%m%d_%H%M%S).log"
ROOT="" MODE="" AUTO=0 ALLOW_XFS=0 BACKEND=""

usage() {
  cat <<EOF
Usage: $(basename "$0") --root PATH [-n|--dry-run|-y|--yes] [--auto] [--allow-crossfs]
Safely hardlink duplicate files under PATH (single filesystem by default).

Options:
  --root PATH          Parent directory to deduplicate (e.g. /backup/backup-games/Games)
  -n, --dry-run        Preview only (no modifications)
  -y, --yes            Real run
  --auto               Non-interactive (must combine with -n or -y)
  --allow-crossfs      Allow deduping across nested mounts (default: refuse)
EOF
}

# === ARGS ===
while (($#)); do
  case "$1" in
    --root) ROOT="${2:?}"; shift;;
    -n|--dry|--dry-run) MODE="dry";;
    -y|--yes) MODE="yes";;
    --auto) AUTO=1;;
    --allow-crossfs) ALLOW_XFS=1;;
    -h|--help) usage; exit 0;;
    *) echo "Unknown: $1" >&2; usage; exit 1;;
  esac; shift
done
[ -n "$ROOT" ] || { echo "ERROR: --root required" >&2; usage; exit 1; }

die(){ echo "ERROR: $*" >&2; exit 1; }
have(){ command -v "$1" >/dev/null 2>&1; }
hr(){ command -v numfmt >/dev/null 2>&1 && numfmt --to=iec --suffix=B "$1" || echo "$1 B"; }

# === BACKEND DETECT ===
pick_backend() {
  if have czkawka_cli; then BACKEND="czkawka"; return; fi
  if have jdupes; then BACKEND="jdupes"; return; fi
  if have rdfind; then BACKEND="rdfind"; return; fi
  die "No czkawka_cli/jdupes/rdfind on PATH"
}

# === SAFETY ===
safety() {
  [ -d "$ROOT" ] || die "No such dir: $ROOT"
  case "$ROOT" in /|/backup|/usr/share/pool) die "Refusing to target a base root: $ROOT" ;; esac
  # filesystem check
  local count
  count=$(findmnt --noheadings --submounts --target "$ROOT" | wc -l | tr -d ' ')
  if [ "$count" -gt 1 ] && [ "$ALLOW_XFS" -eq 0 ]; then
    die "Nested mounts under $ROOT detected. Re-run with --allow-crossfs if intentional."
  fi
  # writability (we need to replace files with hardlinks)
  [ -w "$ROOT" ] || echo "[warn] $ROOT not writable by $(id -un). Some items may fail." >&2
}

# === PREVIEW ===
preview() {
  echo "============== DEDUPE PREVIEW =============="
  echo "ROOT : $ROOT  ($(findmnt -no SOURCE,TARGET,FSTYPE --target "$ROOT" 2>/dev/null || true))"
  echo "TOOL : $BACKEND"
  case "$BACKEND" in
    czkawka)
      echo "CMD  : czkawka_cli dup -d \"$ROOT\""
      ;;
    jdupes)
      echo "CMD  : jdupes -r \"$ROOT\""
      ;;
    rdfind)
      echo "CMD  : rdfind \"$ROOT\""
      ;;
  esac
  echo "============================================"
}

# === RUN ===
run_dry() {
  case "$BACKEND" in
    czkawka)  czkawka_cli dup -d "$ROOT" | tee "$LOG" ;;
    jdupes)   jdupes -r "$ROOT" | tee "$LOG" ;;    # lists duplicate groups
    rdfind)   rdfind -makeresultsfile false -dryrun true "$ROOT" | tee "$LOG" ;;
  esac
  echo "[DRY] No changes. Log: $LOG"
}

run_real() {
  case "$BACKEND" in
    czkawka)  ionice -c2 -n7 nice -n 19 czkawka_cli dup -d "$ROOT" --hardlink | tee "$LOG" ;;
    jdupes)   ionice -c2 -n7 nice -n 19 jdupes -rL "$ROOT" | tee "$LOG" ;;
    rdfind)   ionice -c2 -n7 nice -n 19 rdfind -makeresultsfile false -makehardlinks true "$ROOT" | tee "$LOG" ;;
  esac
  echo "[✓] Completed. Log: $LOG"
}

confirm() {
  if (( AUTO )); then
    [ -n "$MODE" ] || die "--auto requires -n or -y"
    return
  fi
  read -rp "Type EXACT ROOT to confirm, or 'd' dry, 'n' abort: " ans
  case "$ans" in
    n|N) exit 0;;
    d|D) MODE="dry";;
    *) [ "$ans" = "$ROOT" ] || die "Confirmation mismatch"; MODE="yes";;
  esac
}

main() {
  pick_backend
  safety
  preview
  confirm
  if [ "$MODE" = "dry" ]; then run_dry; else run_real; fi
}
main "$@"
