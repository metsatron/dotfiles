# Ensure cursor search path is correct *before* XFCE starts its daemons.
# (Read by most display managers via /etc/X11/Xsession.)
export XCURSOR_PATH="$HOME/.icons:$HOME/.local/share/icons:/usr/local/share/icons:/usr/share/icons"

# Ensure GUI apps inherit the shared SSH agent.
if [ -x "$HOME/.local/bin/ssh-agent-ensure" ]; then
  eval "$("$HOME/.local/bin/ssh-agent-ensure" --print)"
fi

# Optional: keep size/theme dynamic (don’t force); uncomment only if you want a default
# export XCURSOR_SIZE=24
# export XCURSOR_THEME=YourCursorTheme
