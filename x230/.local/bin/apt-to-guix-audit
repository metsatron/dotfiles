#!/usr/bin/env bash
set -euo pipefail
# Takes package names on stdin; prints a 3-column report:
# NAME | FOUND_IN_GUIX | GUIX_PACKAGE_NAME(S)

while IFS= read -r name; do
  [ -z "$name" ] && continue
  # exact-name search first; fallback to fuzzy
  exact="$(guix search --type=package -x "^${name}$" 2>/dev/null || true)"
  fuzzy="$(guix search --type=package "${name}" 2>/dev/null || true)"
  if [ -n "$exact" ]; then
    pkgs=$(printf '%s\n' "$exact" | awk '/^name: /{print $2}')
    echo -e "${name}\tYES\t${pkgs}"
  elif [ -n "$fuzzy" ]; then
    pkgs=$(printf '%s\n' "$fuzzy" | awk '/^name: /{print $2}' | head -n5 | tr '\n' ' ')
    echo -e "${name}\tMAYBE\t${pkgs:-–}"
  else
    echo -e "${name}\tNO\t–"
  fi
done
