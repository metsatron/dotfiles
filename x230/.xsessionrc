# Keep the distro gtk3-nocsd hook from exporting session-wide LD_PRELOAD.
export GTK3_NOCSD_IGNORE=1
export GTK_CSD=0

if [ -d "$HOME/.xsessionrc.d" ]; then
  for xsessionrc_snippet in "$HOME"/.xsessionrc.d/*.sh; do
    [ -r "$xsessionrc_snippet" ] || continue
    set +u
    . "$xsessionrc_snippet"
    set +u
  done
  unset xsessionrc_snippet
fi

# Guix GIO modules are built against Guix's GLib and break system binaries
# like xfce4-session that link against the system GLib. Unset them so the
# session manager uses the system GIO module path instead.
unset GIO_EXTRA_MODULES

# AppMenu is enabled through XFCE xsettings by xfce-appmenu-configure.
# Do not export GTK_MODULES session-wide: terminals and agent children inherit
# it, and Electron/Flatpak CLIs log host GTK module warnings.
unset GTK_MODULES
export UBUNTU_MENUPROXY="${UBUNTU_MENUPROXY:-1}"
export QT_QPA_PLATFORMTHEME="${QT_QPA_PLATFORMTHEME:-gtk2}"

# --- add cursor search path, only if not already set ---
: "${XCURSOR_PATH:=$HOME/.icons:/usr/local/share/icons:/usr/share/icons}"
export XCURSOR_PATH
