" ";; -------------------- Centaur Tabs (stable setup) -----------------------
(require 'centaur-tabs)
(centaur-tabs-mode 1)

(setq centaur-tabs-style \"rounded\"
      centaur-tabs-height 24
      centaur-tabs-set-icons nil
      centaur-tabs-set-close-button nil
      centaur-tabs-set-modified-marker t
      centaur-tabs-modified-marker \"*\"
      centaur-tabs-cycle-scope 'tabs
      centaur-tabs-show-new-tab-button nil
      centaur-tabs-show-navigation-buttons t
      centaur-tabs-group-by-projectile-project t)

;; Robust grouping (avoid special buffers blowing up)
(defun metsatron/centaur-tabs-buffer-groups ()
  (list
   (cond
    ;; Service buffers = no grouping headaches
    ((or (string-prefix-p \" *\" (buffer-name))
         (member (buffer-name)
                 '(\"*spacemacs*\" \"*Messages*\" \"*Compile-Log*\"
                   \"*Help*\" \"*Warnings*\" \"*Backtrace*\"
                   \"*scratch*\" \"*Which Key*\")))
     \"Service\")
    ;; Treemacs/VTerm/magit etc. keep out of main groups
    ((memq major-mode '(treemacs-mode vterm-mode term-mode
                         magit-status-mode magit-process-mode
                         package-menu-mode))
     \"Tools\")
    ;; Project buckets when available
    ((and (fboundp 'projectile-project-name) (projectile-project-p))
     (projectile-project-name))
    (t \"Buffers\"))))
(setq centaur-tabs-buffer-groups-function #'metsatron/centaur-tabs-buffer-groups)

;; Correct hide function signature: (NAME BUFFER) -> t to hide
(defun metsatron/centaur-tabs-hide-tab (name buffer)
  (let ((m (buffer-local-value 'major-mode buffer)))
    (or (string-prefix-p \" *Treemacs\" name)
        (member name '(\"*Which Key*\" \"*spacemacs*\" \"*Messages*\"))
        (memq m '(treemacs-mode which-key-mode spacemacs-buffer-mode)))))
(setq centaur-tabs-hide-tab-function #'metsatron/centaur-tabs-hide-tab)

;; Simply disable the tab-line in specific modes
(dolist (hook '(spacemacs-buffer-mode-hook treemacs-mode-hook which-key-setup-buffer-hook))
  (add-hook hook #'centaur-tabs-local-mode))

;; Firefox-like keys
(global-set-key (kbd \"C-t\")         #'(lambda () (interactive)
                                        (switch-to-buffer (generate-new-buffer \"*untitled*\"))))
(global-set-key (kbd \"<C-prior>\")   #'centaur-tabs-backward)           ; Ctrl+PgUp
(global-set-key (kbd \"<C-next>\")    #'centaur-tabs-forward)            ; Ctrl+PgDn
(global-set-key (kbd \"<C-S-prior>\") #'centaur-tabs-move-current-tab-to-left)
(global-set-key (kbd \"<C-S-next>\")  #'centaur-tabs-move-current-tab-to-right)
(global-set-key (kbd \"C-S-t\")       #'(lambda () (interactive)
                                        (when (and kill-ring (stringp (car kill-ring))
                                                   (file-exists-p (car kill-ring)))
                                          (find-file (car kill-ring)))))
(global-set-key (kbd \"C-S-w\")       #'kill-current-buffer)             ; avoid clobbering Evil's C-w
;; If you insist on C-w like Firefox, uncomment:
;; (global-set-key (kbd \"C-w\") #'kill-current-buffer)
