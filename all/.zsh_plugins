#!/bin/zsh
# ~/.zsh_plugins
[[ $- != *i* ]] && return 0
[[ -n ${DOTCORTEX_ZSH_PLUGINS_LOADED-} ]] && return 0
typeset -g DOTCORTEX_ZSH_PLUGINS_LOADED=1

# Detect "use Guix plugins directly" (either explicit or profile present)
if [[ "${METSA_PLUGINS_FROM_GUIX:-0}" = 1 || -n "$GUIX_PROFILE$HOME/.guix-profile$HOME/.guix-extra-profiles/core/core" ]]; then
  # --- Guix path: source plugins directly (no manager) ---
  # autosuggestions
  for p in \
    "$GUIX_PROFILE/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh" \
    "$HOME/.guix-profile/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh" \
    "$HOME/.guix-extra-profiles/core/core/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh" \
    "/usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh" \
    "/usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh" \
    "/usr/local/share/zsh-autosuggestions/zsh-autosuggestions.zsh"; do
    [[ -r "$p" ]] && { source "$p"; break; }
  done

  # site-functions for completions
  for d in \
    "$GUIX_PROFILE/share/zsh/site-functions" \
    "$HOME/.guix-profile/share/zsh/site-functions" \
    "$HOME/.guix-extra-profiles/core/core/share/zsh/site-functions" \
    "/usr/local/share/zsh/site-functions" \
    "/usr/share/zsh/site-functions"; do
    [[ -d "$d" ]] && { fpath=("$d" $fpath); break; }
  done

  # syntax highlighting last
  if [[ "${ENABLE_SYNTAX_HL:-1}" = 1 ]]; then
    for p in \
      "$GUIX_PROFILE/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" \
      "$HOME/.guix-profile/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" \
      "$HOME/.guix-extra-profiles/core/core/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" \
      "/usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" \
      "/usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" \
      "/usr/local/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"; do
      [[ -r "$p" ]] && { source "$p"; break; }
    done
  fi
else
  # --- Non-Guix path: use zplug (no auto-install, no p10k) ---
  if [[ -r "$HOME/.zplug/init.zsh" ]]; then
    source "$HOME/.zplug/init.zsh"
    # Plugins you used via zplug, except p10k
    zplug "zsh-users/zsh-completions", from:github, defer:0
    zplug "zsh-users/zsh-autosuggestions", from:github, defer:2, on:"zsh-users/zsh-completions"
    # syntax highlighting LAST (optional)
    if [[ "${ENABLE_SYNTAX_HL:-1}" = 1 ]]; then
      zplug "zsh-users/zsh-syntax-highlighting", from:github, defer:3
    fi
    # IMPORTANT: load only; don't auto-install or update on startup
    zplug load
  fi
fi

# Safety: if autosuggestions widget missing, provide a no-op for your keybind
if ! zle -la | grep -q '^autosuggest-toggle$'; then
  autosuggest-toggle() { :; }
  zle -N autosuggest-toggle
fi
