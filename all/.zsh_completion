#!/bin/zsh
# No noisy rm; just initialize once into XDG cache.
if [[ $- == *i* && -z ${DOTCORTEX_ZSH_COMPLETION_INIT-} ]]; then
  typeset -g DOTCORTEX_ZSH_COMPLETION_INIT=1
  autoload -Uz compinit
  mkdir -p "${XDG_CACHE_HOME:-$HOME/.cache}"
  compinit -d "${XDG_CACHE_HOME:-$HOME/.cache}/zcompdump"
fi

# --- fzf-tab (after compinit) ---
# helper: source the first readable file from a list
_src_first() { for p in "$@"; do [[ -r "$p" ]] && { source "$p"; return 0; }; done; return 1; }

# Guix and common system locations
if [[ -z ${DOTCORTEX_ZSH_FZF_TAB_LOADED-} ]]; then
  if _src_first \
    "$GUIX_PROFILE/share/fzf-tab/fzf-tab.plugin.zsh" \
    "$GUIX_PROFILE/share/zsh/plugins/fzf-tab/fzf-tab.plugin.zsh" \
    /usr/share/zsh/plugins/fzf-tab/fzf-tab.plugin.zsh \
    /usr/share/fzf-tab/fzf-tab.plugin.zsh \
    /usr/share/zsh/site-contrib/fzf-tab/fzf-tab.plugin.zsh \
    /usr/share/zsh/site-functions/fzf-tab.plugin.zsh 2>/dev/null; then
    typeset -g DOTCORTEX_ZSH_FZF_TAB_LOADED=1
  fi
fi

# minimal styles that play nicely with your existing completion setup
zstyle ':completion:*' menu select
zstyle ':fzf-tab:*'   switch-group ',' '.'
# optional: quick preview for files
zstyle ':fzf-tab:complete:*:*' fzf-preview '[[ -d ${realpath} ]] && ls -la --color=always ${realpath} || bat --style=plain --color=always -n ${realpath} 2>/dev/null || less -R ${realpath}'
