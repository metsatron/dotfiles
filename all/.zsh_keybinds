#!/bin/zsh
# ~/.zsh_keybinds

# Ensure default keymaps exist, then switch to vi mode
bindkey -d
bindkey -v

bindkey "$terminfo[khome]" beginning-of-line
bindkey "$terminfo[kend]"  end-of-line
bindkey "$terminfo[kich1]" overwrite-mode
bindkey "$terminfo[kdch1]" delete-char
bindkey "$terminfo[kcuu1]" up-line-or-history
bindkey "$terminfo[kcud1]" down-line-or-history
bindkey "$terminfo[kcub1]" backward-char
bindkey "$terminfo[kcuf1]" forward-char
bindkey "\e[1;5D"          backward-word
bindkey "\e[1;5C"          forward-word
bindkey "\e[Z"             reverse-menu-complete
bindkey "^e"               edit-command-line

_dotcortex_tab_or_loom() {
  local prefix query verb

  if [[ -n "$RBUFFER" ]] || (( ! $+commands[loom] )) || (( ! $+commands[fzf] )); then
    zle expand-or-complete
    return
  fi

  if [[ "$LBUFFER" =~ '^(.*[[:space:];|&])?loom[[:space:]]*([^[:space:]]*)$' ]]; then
    prefix=${match[1]-}
    query=${match[2]-}
    verb=$(loompick "$query")
    if [[ -n "$verb" ]]; then
      LBUFFER="${prefix}loom ${verb}"
      zle redisplay
      return
    fi
  fi

  zle expand-or-complete
}

zle -N _dotcortex_tab_or_loom
bindkey '^I' _dotcortex_tab_or_loom

# Only bind autosuggestions toggle if that widget exists
if zle -la | grep -qx autosuggest-toggle; then
  bindkey '^T' autosuggest-toggle
fi

bindkey -M isearch . self-insert

autoload edit-command-line
zle -N edit-command-line

if (( ${+terminfo[smkx]} )) && (( ${+terminfo[rmkx]} )); then
  function zle-line-init   { printf "%s" ${terminfo[smkx]} }
  function zle-line-finish { printf "%s" ${terminfo[rmkx]} }
  zle -N zle-line-init
  zle -N zle-line-finish
fi
