# Default: ignore everything
*

# But not these files:
!.gitignore
!.gitattributes
!.gitmodules
!README.md
!docs/

# ——— ALLOWLIST START (edit to taste) ———
# Example: core hand-woven texts
!BookOfAstra/
BookOfAstra/*
!BookOfAstra/**.md

# Example: TimeArk shrine & NPC lore (Markdown only)
!CORTEX/
!CORTEX/TimeArk/
CORTEX/TimeArk/*
!CORTEX/TimeArk/**.md

# Example: FORGE scripts you actually maintain by hand
!FORGE/
!FORGE/**/
!FORGE/**/*.py
!FORGE/**/*.sh
!FORGE/**/*.md

# Example: ROOTS curated notes (but not big binary drops)
!ROOTS/
ROOTS/*
!ROOTS/**/
!ROOTS/**/*.md
!ROOTS/**/*.json

# Keep the submodule path visible (gitlink)
!NEXUS/
!NEXUS/git/
!NEXUS/git/genshin-optimizer
# ——— ALLOWLIST END ———

# --- submodule allowlist ---
!.gitmodules
!NEXUS/
!NEXUS/git/
!NEXUS/git/genshin-optimizer/

# Safety markers & ephemeral
**/.canary
**/__pycache__/
*.pyc
