#!/bin/bash
# ~/.bash_exports
# --------------------------------------------------
# Mètsàtron's Exports
# --------------------------------------------------

export SHOW_LUMENASTRA_GREETING=1
export SHOW_FORTUNE=1
export SHOW_NEOFETCH=1

# Add local bin directories to PATH
custom_paths=(
  "$HOME/bin"
  "$HOME/.local/bin"
  "$HOME/Apps"
  "$HOME/.scripts"
  "$HOME/HelmCortex/FORGE/scripts"
  "$HOME/HelmCortex/FORGE/PixelForge/scripts"
  "$HOME/stl/prefix"
)

for dir in "${custom_paths[@]}"; do
  [ -d "$dir" ] && PATH="$dir:$PATH"
done
export PATH

[ -e /usr/lib/x86_64-linux-gnu/libgtk3-nocsd.so.0 ] && export LD_PRELOAD=/usr/lib/x86_64-linux-gnu/libgtk3-nocsd.so.0

# GCC colors (commented)
#export GCC_COLORS='error=01;31:warning=01;35:note=01;36:caret=01;32:locus=01:quote=01'

# Load dircolors if available
if command -v dircolors >/dev/null 2>&1; then
  if [ -f "$HOME/.dir_colors" ]; then
    eval "$(dircolors -b "$HOME/.dir_colors")"
  else
    eval "$(dircolors -b)"
  fi
fi

# don't put duplicate lines or lines starting with space in the history.
HISTCONTROL=ignoreboth

# history length
HISTSIZE=10000
HISTFILESIZE=20000

# Lesspipe
[ -x /usr/bin/lesspipe ] && eval "$(SHELL=/bin/sh lesspipe)"

# ProtonUp-Qt PATH addition
if [ -d "/home/metsatron/stl/prefix" ]; then export PATH="$PATH:/home/metsatron/stl/prefix"; fi

if command -v powerline-daemon >/dev/null 2>&1; then
  powerline-daemon -q
  POWERLINE_BASH_CONTINUATION=1
  POWERLINE_BASH_SELECT=1
  . /usr/share/powerline/bindings/bash/powerline.sh 2>/dev/null || true
fi

# Arch Linux command-not-found hook
if [ -f /etc/arch-release ] && [ -r /usr/share/doc/pkgfile/command-not-found.bash ]; then
    . /usr/share/doc/pkgfile/command-not-found.bash
fi

