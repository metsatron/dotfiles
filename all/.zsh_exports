#!/bin/zsh
# ~/.zsh_exports
# PATH and common exports
KEYTIMEOUT=1
export PVOX_CLIP_PLAYER="ffplay -v error -nodisp -autoexit -"
export OMP_NUM_THREADS=2
export OPENBLAS_NUM_THREADS=2
export SHOW_LUMENASTRA_GREETING=0
export SHOW_FORTUNE=0
export SHOW_NEOFETCH=0

# Put /usr/local first (portable PATH edit)
export PATH="/usr/local/bin:/usr/local/sbin:$PATH"

# X session startup owns GTK no-CSD/appmenu env. Do not rewrite
# LD_PRELOAD in shell startup; that changes behavior for child GUI apps.

# dircolors
if command -v dircolors >/dev/null 2>&1; then
  if [ -f "$HOME/.dir_colors" ]; then
    eval "$(dircolors -b "$HOME/.dir_colors")"
  else
    eval "$(dircolors -b)"
  fi
fi

# lesspipe
[ -x /usr/bin/lesspipe ] && eval "$(SHELL=/bin/sh lesspipe)"

# ProtonUp-Qt PATH tail
if [ -d "/home/metsatron/stl/prefix" ]; then
  export PATH="$PATH:/home/metsatron/stl/prefix"
fi

# Guix "current" on PATH only
if [ -d "$HOME/.config/guix/current" ]; then
  export PATH="$HOME/.config/guix/current/bin:$PATH"
  export INFOPATH="$HOME/.config/guix/current/share/info:$INFOPATH"
fi

# Source main user Guix profile once, if present
if [ -L "$HOME/.guix-profile" ] && [ -z "${__GUIX_MAIN_PROFILE_SOURCED+x}" ]; then
  export __GUIX_MAIN_PROFILE_SOURCED=1
  GUIX_PROFILE="$HOME/.guix-profile"
  . "$GUIX_PROFILE/etc/profile"
fi

# Source per-profile 'core' once, if present
# Guard by PATH contents (not just env var) so we retry if prior sourcing failed
if [ -r "$HOME/.guix-extra-profiles/core/core/etc/profile" ]; then
  case ":$PATH:" in
    *":$HOME/.guix-extra-profiles/core/core/bin:"*) ;;  # already in PATH, skip
    *)
      export __GUIX_CORE_PROFILE_SOURCED=1
      export GUIX_PROFILE="$HOME/.guix-extra-profiles/core/core"
      . "$GUIX_PROFILE/etc/profile"
      # Guix profile sets EMACSLOADPATH without trailing : so Emacs loses defaults (cl-lib etc)
      [[ -n "${EMACSLOADPATH:-}" && "${EMACSLOADPATH}" != *: ]] && export EMACSLOADPATH="${EMACSLOADPATH}:"
      # Locales for this profile
      if [ -d "$GUIX_PROFILE/lib/locale" ]; then
        export GUIX_LOCPATH="$GUIX_PROFILE/lib/locale"
      fi
      ;;
  esac
fi

# Stop runtime loader from picking Guix libs for host binaries like /bin/ps
unset LD_LIBRARY_PATH

# Only add PATH entries that are actually traversable; dead mounts can make
# /usr/bin/env fail interpreter lookup with ENOTCONN.
path_dir_healthy() {
  [ -d "$1" ] || return 1
  ls -d "$1" >/dev/null 2>&1
}

# Homebrew / Linuxbrew
if path_dir_healthy "/home/linuxbrew/.linuxbrew/bin"; then
  export HOMEBREW_PREFIX="${HOMEBREW_PREFIX:-/home/linuxbrew/.linuxbrew}"
  export PATH="$HOMEBREW_PREFIX/bin:$HOMEBREW_PREFIX/sbin:$PATH"
elif path_dir_healthy "/opt/homebrew/bin"; then
  export HOMEBREW_PREFIX="${HOMEBREW_PREFIX:-/opt/homebrew}"
  export PATH="$HOMEBREW_PREFIX/bin:$HOMEBREW_PREFIX/sbin:$PATH"
fi

# Shared SSH agent for shells and GUI-launched tools
if [ -x "$HOME/.local/bin/ssh-agent-ensure" ]; then
  eval "$("$HOME/.local/bin/ssh-agent-ensure" --print)"
fi

case $- in
  *i*)
    if [ -f "$HOME/.ssh/id_ed25519" ] && command -v ssh-add >/dev/null 2>&1 && { [ -t 0 ] || [ -t 1 ] || [ -t 2 ]; }; then
      if ! ssh-add -l >/dev/null 2>&1; then
        ssh-add "$HOME/.ssh/id_ed25519" </dev/tty >/dev/null 2>&1 || true
      fi
    fi
    ;;
esac

# Simple colon-list deduper for bash/zsh (no output)
dedupe_path_var() {
  local name="$1" val new elem
  eval "val=\${$name}"
  new=
  IFS=':'
  for elem in $val; do
    [ -z "$elem" ] && continue
    case ":$new:" in
      *:"$elem":*) ;;
      *) new="${new:+$new:}$elem" ;;
    esac
  done
  eval "export $name=\$new"
}
[ -n "$LIBRARY_PATH" ]    && dedupe_path_var LIBRARY_PATH
[ -n "$GUIX_PYTHONPATH" ] && dedupe_path_var GUIX_PYTHONPATH

# fnm: tell it the shell explicitly to avoid calling `ps`
FNM_PATH="/home/metsatron/.local/share/fnm"
if path_dir_healthy "$FNM_PATH"; then
  export PATH="$FNM_PATH:$PATH"
  if [ -n "$ZSH_VERSION" ]; then
    eval "$(fnm env --shell=zsh --use-on-cd)"
  elif [ -n "$BASH_VERSION" ]; then
    eval "$(fnm env --shell=bash --use-on-cd)"
  else
    # Fallback with no inference, still avoids ps
    eval "$(fnm env)"
  fi
fi

# Optional user-defined PATH extras (works even if array not set)
for dir in ${custom_paths:+${custom_paths[@]}}; do
  path_dir_healthy "$dir" && PATH="$dir:$PATH"
done

# Priority: ~/.local/bin/claude (canonical) > ~/.config/Claude native app >
# Antigravity/VSCodium extension > npm global.
# Always prepend the best native binary so it wins over any npm-installed claude.
_claude_found=

# Tier 1: ~/.local/bin/claude (managed symlink / manual install)
if [ -x "$HOME/.local/bin/claude" ]; then
  export PATH="$HOME/.local/bin:$PATH"
  _claude_found=local

# Tier 2: newest versioned dir under Claude app install locations
else
  for _claude_base in \
    "$HOME/.config/Claude/claude-code" \
    "$HOME/.config/Claude/claude-code-vm"
  do
    [ -d "$_claude_base" ] || continue
    _claude_native_dir="$(find "$_claude_base" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort -V | tail -n 1)"
    if [ -n "$_claude_native_dir" ] && [ -x "$_claude_native_dir/claude" ]; then
      export PATH="$_claude_native_dir:$PATH"
      _claude_found=native
      break
    fi
  done

  # Tier 3: Antigravity / VSCodium extension managed binary
  if [ -z "$_claude_found" ] && [ -d "$HOME/.antigravity/extensions" ]; then
    _claude_ext_dir="$(find "$HOME/.antigravity/extensions" -path '*/resources/native-binary' -type d 2>/dev/null | sort -V | tail -n 1)"
    if [ -n "${_claude_ext_dir:-}" ] && [ -x "$_claude_ext_dir/claude" ]; then
      export PATH="$_claude_ext_dir:$PATH"
      _claude_found=antigravity
    fi
    unset _claude_ext_dir
  fi

  unset _claude_base _claude_native_dir
fi

unset _claude_found

export PATH

# Editor
export EDITOR=${EDITOR:-nvim}
export VISUAL=${VISUAL:-$EDITOR}

# History hygiene for bash
HISTCONTROL=ignoreboth


# Use zsh's special path array (keeps PATH in sync) and dedupe entries
typeset -U path

# Mètsàtron's custom paths — append only if they exist
for dir in \
  "$HOME/bin" \
  "$HOME/.local/bin" \
  "$HOME/.cargo/bin" \
  "$HOME/Apps" \
  "$HOME/HelmCortex/FORGE/bin" \
  "$HOME/HelmCortex/FORGE/scripts" \
  "$HOME/HelmCortex/FORGE/PixelForge/bin" \
  "$HOME/HelmCortex/FORGE/PixelForge/scripts" \
  "$HOME/HelmCortex/FORGE/VoxForge/bin" \
  "$HOME/HelmCortex/FORGE/VoxForge/scripts" \
  "$HOME/stl/prefix"
do
  path_dir_healthy "$dir" && path+="$dir"
done
