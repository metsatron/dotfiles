#!/bin/zsh
# ~/.zsh_exports
# PATH and common exports

# Standard /usr/local at front
path=(/usr/local/bin /usr/local/sbin $path)

# Mètsàtron's custom paths
for dir in \
    "$HOME/bin" \
    "$HOME/.local/bin" \
    "$HOME/Apps" \
    "$HOME/.scripts" \
    "$HOME/HelmCortex/FORGE/scripts" \
    "$HOME/HelmCortex/FORGE/PixelForge/scripts" \
    "$HOME/stl/prefix"; do
  [ -d "$dir" ] && path+=("$dir")
done

export EDITOR=/usr/bin/vim
export VISUAL=/usr/bin/vim
export KEYTIMEOUT=1

