{
  "data": {},
  "mcpServers": {
    "brave-search": {
      "command": "bash",
      "args": [
        "-lc",
        "exec \"$HOME/.local/bin/opencode-mcp-brave-search\""
      ]
    }
  },
  "tui": {
    "theme": "opencode"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook-user-prompt-submit"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook-stop"
          }
        ]
      }
    ]
  },
  "shell": {}
}
