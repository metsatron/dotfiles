#!/bin/zsh
# ~/.zsh_functions

bk() { cp -a "$1" "${1}_$(date --iso-8601=seconds)"; }

rationalise-dot() {
  if [[ $LBUFFER = *.. ]]; then
    LBUFFER+=/..
  else
    LBUFFER+=.
  fi
}
zle -N rationalise-dot

unalias launch 2>/dev/null
launch() {
    type "$1" >/dev/null || { print "$1 not found" && return 1 }
    "$@" &>/dev/null &|
}

urlencode() {
  print "${${(j: :)@}//(#b)(?)/%$[[##16]##${match[1]}]}"
}

myip() {
  local api
  case "$1" in
    "-4") api="http://v4.ipv6-test.com/api/myip.php" ;;
    "-6") api="http://v6.ipv6-test.com/api/myip.php" ;;
    *) api="http://ipv6-test.com/api/myip.php" ;;
  esac
  curl -s "$api"
  echo
}

lscolors() {
  ((cols = $COLUMNS - 4))
  s=$(printf %${cols}s)
  for i in {000..$(tput colors)}; do
    echo -e $i $(tput setaf $i; tput setab $i)${s// /=}$(tput op);
  done
}

hr() {
  print ${(l:COLUMNS::=:)}
}

htmime() {
  if [[ -z $1 ]]; then
    print "USAGE: htmime <URL>"
    return 1
  fi
  mime=$(curl -sIX HEAD $1 | sed -nr "s/Content-Type: (.+)/\1/p")
  print $mime
}

zplug-update-all() {
  echo "✨ Updating zplug plugins..."
  zplug update
  zplug clean --force
  echo "✅ zplug update complete."
}

