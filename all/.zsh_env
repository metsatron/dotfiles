#!/bin/zsh
# ~/.zsh_env
# Environment variables (XDG Base Directory spec, TERM)

# Claude Code sets CLAUDECODE=1 in child processes to block nesting.
# This leaks into tmux panes and terminal emulators spawned from a claude
# session, preventing new claude launches. Clear it for every new shell.
unset CLAUDECODE 2>/dev/null

export TERM="xterm-256color"

# Flatpak sandboxes redirect XDG dirs into ~/.var/app/<id>/ which breaks
# host tools (loom, guile, emacs). Force canonical paths regardless.
export XDG_DATA_HOME=$HOME/.local/share
export XDG_CONFIG_HOME=$HOME/.config
export XDG_CACHE_HOME=$HOME/.cache

if [[ -z $XDG_DATA_DIRS ]]; then
  export XDG_DATA_DIRS=/usr/local/share:/usr/share
fi

if [[ -z $XDG_CONFIG_DIRS ]]; then
  export XDG_CONFIG_DIRS=/etc/xdg
else
  export XDG_CONFIG_DIRS="/etc/xdg:$XDG_CONFIG_DIRS"
fi
