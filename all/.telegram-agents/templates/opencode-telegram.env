# OpenCode Telegram Bot Env Template


# [[file:../../../telegram-agents.org::*OpenCode Telegram Bot Env Template][OpenCode Telegram Bot Env Template:1]]
# OpenCode Telegram Bot Configuration
# Copy to ~/.config/opencode-telegram-bot/.env on target machine

TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_ALLOWED_USER_ID=YOUR_USER_ID
OPENCODE_API_URL=http://localhost:4096
OPENCODE_MODEL_PROVIDER=opencode
OPENCODE_MODEL_ID=big-pickle
BOT_LOCALE=en
TASK_LIMIT=10
# OpenCode Telegram Bot Env Template:1 ends here
