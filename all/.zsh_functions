#!/bin/zsh
# ~/.zsh_functions

# speak with an agent/model quickly
pvoice() { pvox say "$@"; }

# render a transcript file to a single wav and play it
prender() { pvox render "$@"; }

# read clipboard with a chosen agent (for panel launcher / browser)
pclip() {
  local agent="${1:-ChatGPT}" text
  if command -v xclip >/dev/null 2>&1; then
    text="$(xclip -o -selection clipboard)"
  elif command -v xsel >/dev/null 2>&1; then
    text="$(xsel -ob)"
  else
    print -u2 "Install xclip or xsel to use pclip."
    return 1
  fi
  pvox say "$agent" "$text"
}

bk() { cp -a "$1" "${1}_$(date --iso-8601=seconds)"; }

rationalise-dot() {
  if [[ $LBUFFER = *.. ]]; then
    LBUFFER+=/..
  else
    LBUFFER+=.
  fi
}
zle -N rationalise-dot

unalias launch 2>/dev/null
launch() {
    type "$1" >/dev/null || { print "$1 not found" && return 1 }
    "$@" &>/dev/null &|
}

urlencode() {
  print "${${(j: :)@}//(#b)(?)/%$[[##16]##${match[1]}]}"
}

myip() {
  local api
  case "$1" in
    "-4") api="http://v4.ipv6-test.com/api/myip.php" ;;
    "-6") api="http://v6.ipv6-test.com/api/myip.php" ;;
    *) api="http://ipv6-test.com/api/myip.php" ;;
  esac
  curl -s "$api"
  echo
}

lscolors() {
  ((cols = $COLUMNS - 4))
  s=$(printf %${cols}s)
  for i in {000..$(tput colors)}; do
    echo -e $i $(tput setaf $i; tput setab $i)${s// /=}$(tput op);
  done
}

hr() {
  print ${(l:COLUMNS::=:)}
}

htmime() {
  if [[ -z $1 ]]; then
    print "USAGE: htmime <URL>"
    return 1
  fi
  mime=$(curl -sIX HEAD $1 | sed -nr "s/Content-Type: (.+)/\1/p")
  print $mime
}

zplug-update-all() {
  echo "✨ Updating zplug plugins..."
  zplug update
  zplug clean --force
  echo "✅ zplug update complete."
}

function chatgpt-process-export() {
  local export_dir=~/HelmCortex/LOGS/ChatGPT/EXPORT
  local today=$(date +%y%m%d)
  local zip_src="$export_dir/chatgpt-export-markdown.zip"
  local zip_dst="$export_dir/chatgpt-export-markdown-$today.zip"
  local extract_dir="$export_dir/chatgpt-export-markdown-$today"

  # Rename with timestamp
  if [[ -f "$zip_src" ]]; then
    mv "$zip_src" "$zip_dst"
    echo "✅ Renamed to $zip_dst"
  else
    echo "❌ Source ZIP not found: $zip_src"
    return 1
  fi

  # Extract to dated folder
  mkdir -p "$extract_dir"
  unzip "$zip_dst" -d "$extract_dir"
  echo "✅ Extracted to $extract_dir"
}

