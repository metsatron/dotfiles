#!/bin/zsh
termfont_sync() {
  local f=""
  if [[ -n ${WEZTERM_FONT-} ]]; then
    f=$WEZTERM_FONT
  elif command -v fc-match >/dev/null 2>&1; then
    f="$(fc-match -f '%{family}\n' 2>/dev/null | head -n1)"
  fi

  [[ -n $f ]] || return 0
  export TERM_FONT="$f"
  export TERMINAL_FONT="$f"
  export TERMINALFONT="$f"
}

rationalise-dot() {
  if [[ $LBUFFER = *.. ]]; then
    LBUFFER+=/..
  else
    LBUFFER+=.
  fi
}
zle -N rationalise-dot

zplug-update-all() {
  echo "✨ Updating zplug plugins..."
  zplug update
  zplug clean --force
  echo "✅ zplug update complete."
}

autoload zmv

# --- Lumen/WezTerm tab title support ---------------------------------

# Require add-zsh-hook (standard in modern zsh)
autoload -U add-zsh-hook

# Set the title before each prompt (idle state)
la_term_title_precmd() {
  emulate -L zsh
  local base="${PWD:t}"
  printf '\e]2;%s\a' "$base"
}

# Set the title when a command is *about to run*
la_term_title_preexec() {
  emulate -L zsh
  # $1 is the full command line, grab just first word
  local cmd="$1"
  local prog="${cmd%% *}"

  # if it looks like a flatpak-spawn wrapper, try to surface the inner thing
  if [[ "$prog" == flatpak-spawn ]]; then
    # crude but good enough: look for last word
    prog="${cmd##* }"
  fi

  # keep it short (nvim, htop, btop, etc)
  printf '\e]2;%s\a' "$prog"
}

add-zsh-hook precmd  la_term_title_precmd
add-zsh-hook preexec la_term_title_preexec
