# ~/DotCortex/all/.local/share/dotcortex/manifests/bun/build.ssv
# NAME MODE ROOT REPO REF SUBDIR INSTALL BUILD HEALTH EXTRA
# maestro submodule vendor/agent-maestro https://github.com/subhangR/agent-maestro.git main . "" "bun run build:all" "" ""
codex-desktop-linux git ~/.local/share/dotcortex/src/codex-desktop-linux https://github.com/ilysenko/codex-desktop-linux.git main . "./install.sh" "python3 -c 'from pathlib import Path; import re; p=Path(\"codex-app/start.sh\"); text=p.read_text(); repl=\"SCRIPT_DIR=\\\"$(cd \\\"$(dirname \\\"$(readlink -f \\\"${BASH_SOURCE[0]:-$0}\\\")\\\")\\\" && pwd -P)\\\"\"; text=re.sub(r\"^SCRIPT_DIR=.*$\", repl, text, count=1, flags=re.M); p.write_text(text)' && mkdir -p \"$HOME/.local/share/applications\" \"$HOME/.local/share/icons/hicolor/256x256/apps\" && ln -sf \"$PWD/assets/codex.png\" \"$HOME/.local/share/icons/hicolor/256x256/apps/codex-desktop.png\" && printf '%s\n' '[Desktop Entry]' 'Name=Codex Desktop' 'Comment=OpenAI Codex desktop app' \"Exec=env PATH=$HOME/.npm-global/bin:$HOME/.local/bin:/usr/local/bin:/usr/bin:/bin $HOME/.local/bin/codex-desktop\" 'Icon=codex-desktop' 'Terminal=false' 'Type=Application' 'Categories=Development;Chat;' 'StartupWMClass=codex-desktop' 'X-GNOME-WMClass=codex-desktop' > \"$HOME/.local/share/applications/codex-desktop.desktop\" && command -v update-desktop-database >/dev/null 2>&1 && update-desktop-database \"$HOME/.local/share/applications\" >/dev/null 2>&1 || true" ""
