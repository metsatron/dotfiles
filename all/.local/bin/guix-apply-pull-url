#!/usr/bin/env bash
# Apply cached Guix pull mirror (no bench)

# [[file:../../../guix.org::*Apply cached Guix pull mirror (no bench)][Apply cached Guix pull mirror (no bench):1]]
#!/usr/bin/env bash
# Usage:
#   guix-apply-pull-url [URL]
# Behavior:
#   - If URL arg given → use that.
#   - Else read ~/.config/guix/.bench/pull-url.
#   - Never runs the bench itself.
set -Eeuo pipefail

CACHE="$HOME/.config/guix/.bench/pull-url"
URL="${1:-}"

if [[ -z "$URL" ]]; then
  [[ -r "$CACHE" ]] || { echo "No cached mirror. Run 'loom guix:pull-bench' first or pass URL." >&2; exit 1; }
  URL="$(tr -d $'\r\n' < "$CACHE")"
fi

REPO_DIR="$HOME/.dotfiles/all/.config/guix"
CHAN_FILE="$REPO_DIR/channels.scm"
mkdir -p "$REPO_DIR"
ts="$(date +%Y%m%d-%H%M%S)"
[[ -f "$CHAN_FILE" ]] && cp -a "$CHAN_FILE" "$CHAN_FILE.bak.$ts"

# Official guix channel introduction (stable across mirrors)
INTRO_COMMIT="9edb3f66fd807b096b48283debdcddccfea34bad"
INTRO_FP="BBB0 2DDF 2E8C 26C5 7D28  9DDA 013A 06C9 4F2A E8C4"

tmp="$(mktemp)"
cat >"$tmp" <<EOF
;; Auto-generated by guix-apply-pull-url on $ts
;; Mirror chosen: $URL
(list
  (channel
    (name 'guix)
    (url "$URL")
    (introduction
      (make-channel-introduction
        "$INTRO_COMMIT"
        (openpgp-fingerprint "$INTRO_FP")))))
EOF

install -m 0644 "$tmp" "$CHAN_FILE"
rm -f "$tmp"

echo "Updated repo file:"
echo "  $CHAN_FILE"
echo "Mirror: $URL"
echo "→ Run 'loom stow' to deploy into ~/.config/guix/channels.scm"
# Apply cached Guix pull mirror (no bench):1 ends here
