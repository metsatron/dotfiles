#!/usr/bin/env bash
# NVIM_APPNAME picker using fzf. Works with your Stow layout.
# Usage:
#   nvms                 # pick profile
#   nvms astronvim -- README.md

set -u

CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"

list_candidates() {
  # Seed with common names, then auto-discover ~/.config/*
  printf "%s\n" "nvim" "astronvim" "lazyvim" "nvchad" "kickstart"
  for d in "$CONFIG_HOME"/*; do
    [ -d "$d" ] || continue
    name="$(basename "$d")"
    case "$name" in nvim) continue ;; esac
    if [ -f "$d/init.lua" ] || [ -f "$d/init.vim" ] || [ -d "$d/lua" ]; then
      printf "%s\n" "$name"
    fi
  done | sort -u
}

pick="${1:-}"
shift || true

if [ -z "${pick:-}" ] || [[ "$pick" == -* ]]; then
  if ! command -v fzf >/dev/null 2>&1; then
    printf "fzf is required for interactive mode\n" >&2
    exit 2
  fi
  pick="$(list_candidates | fzf --prompt='NVIM_APPNAME > ' --height=15 --reverse)" || exit 130
fi

export NVIM_APPNAME="$pick"
exec nvim "$@"
