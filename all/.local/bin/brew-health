#!/usr/bin/env bash
# Health

# [[file:../../../homebrew.org::*Health][Health:1]]
# ~/.dotfiles/all/.local/bin/brew-health
set -euo pipefail

"$HOME/.local/bin/dotcortex-brew-env" bash -lc '
echo "HOMEBREW_PREFIX=${HOMEBREW_PREFIX:-$(brew --prefix 2>/dev/null || echo unknown)}"
command -v brew || echo "brew not in PATH"
brew --version
echo
brew config || true
'
# Health:1 ends here
