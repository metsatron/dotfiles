#!/usr/bin/env bash
#!/usr/bin/env bash
set -euo pipefail

eval "$("$HOME/.local/bin/ssh-agent-ensure" --print)"

if command -v dbus-update-activation-environment >/dev/null 2>&1; then
  dbus-update-activation-environment SSH_AUTH_SOCK SSH_AGENT_PID
fi

if command -v systemctl >/dev/null 2>&1; then
  systemctl --user import-environment SSH_AUTH_SOCK SSH_AGENT_PID >/dev/null 2>&1 || true
fi
