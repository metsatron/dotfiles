#!/usr/bin/env bash
# [[file:../../../loom.org::*Maak control plane (Scheme, XDG-friendly)][Maak control plane (Scheme, XDG-friendly):3]]
set -euo pipefail

ROOT="$HOME/DotCortex"

exec emacs --batch -Q \
  --eval "(setq create-lockfiles nil make-backup-files nil auto-save-default nil backup-inhibited t vc-make-backup-files nil)" \
  --eval "(load-file \"$ROOT/all/.local/bin/dotfiles-batch.el\")" \
  --eval "(dotfiles-batch-tangle-files \"$ROOT\" \"agents.org\" \"skills.org\" \"hooks.org\")"
# Maak control plane (Scheme, XDG-friendly):3 ends here
