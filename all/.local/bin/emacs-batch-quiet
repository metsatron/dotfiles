#!/usr/bin/env bash
# Batch Emacs (quiet harmless banners)

# [[file:../../../guix.org::*Batch Emacs (quiet harmless banners)][Batch Emacs (quiet harmless banners):1]]
set -Eeuo pipefail
EMACS_BIN="$(command -v emacs)"
exec /bin/bash -c '
  {
    exec 3>&1
    exec 4>&2
    "'"$EMACS_BIN"'" "$@" \
      2> >(grep -v -E "(no version information available).*(libxml2|librsvg|libm17n-core)" >&4) \
      1>&3
  }
' bash "$@"
# Batch Emacs (quiet harmless banners):1 ends here
