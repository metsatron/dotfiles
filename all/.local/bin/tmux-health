#!/usr/bin/env bash
#!/usr/bin/env bash
set -euo pipefail

echo "== tmux health =="

if command -v tmux >/dev/null 2>&1; then
  echo "[tmux] $(tmux -V) at $(command -v tmux)"
else
  echo "[tmux] NOT FOUND"
fi

TPM_DIR="${HOME}/.config/tmux/plugins/tpm"
if [ -d "$TPM_DIR" ]; then
  echo "[tpm] installed at $TPM_DIR"
else
  echo "[tpm] NOT INSTALLED -- run tmux-bootstrap"
fi

for plugin in tmux-resurrect tmux-continuum tmux-yank tmux-sensible; do
  dir="${HOME}/.config/tmux/plugins/$plugin"
  if [ -d "$dir" ]; then
    echo "[$plugin] installed"
  else
    echo "[$plugin] NOT INSTALLED"
  fi
done

RESURRECT_DIR="${HOME}/.local/share/tmux/resurrect"
if [ -d "$RESURRECT_DIR" ]; then
  count=$(find "$RESURRECT_DIR" -name "*.txt" -type f 2>/dev/null | wc -l)
  latest=$(ls -1t "$RESURRECT_DIR"/*.txt 2>/dev/null | head -1 || true)
  echo "[resurrect] $count saves in $RESURRECT_DIR"
  if [ -n "$latest" ]; then
    echo "[resurrect] latest: $(basename "$latest")"
  fi
  if [ -L "$RESURRECT_DIR/last" ]; then
    last_target=$(readlink "$RESURRECT_DIR/last" 2>/dev/null || true)
    echo "[resurrect] last: $last_target"
    if [ -e "$RESURRECT_DIR/last" ]; then
      echo "[resurrect] last link ok"
    else
      echo "[resurrect] last link is dangling"
    fi
  elif [ -e "$RESURRECT_DIR/last" ]; then
    echo "[resurrect] last exists but is not a symlink"
  else
    echo "[resurrect] last is missing"
  fi
else
  echo "[resurrect] save dir not found"
fi

if tmux list-sessions 2>/dev/null; then
  echo "[server] tmux server running"
else
  echo "[server] no tmux server"
fi
