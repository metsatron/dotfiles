#!/usr/bin/env python3
from __future__ import annotations

import argparse
import shutil
import sys
from pathlib import Path


SKIP = {"manifest"}


def copy_entry(src: Path, dst: Path) -> None:
    if src.is_dir() and not src.is_symlink():
        shutil.copytree(src, dst, symlinks=True, dirs_exist_ok=True)
    else:
        dst.parent.mkdir(parents=True, exist_ok=True)
        if dst.exists() or dst.is_symlink():
            if dst.is_dir() and not dst.is_symlink():
                shutil.rmtree(dst)
            else:
                dst.unlink()
        shutil.copy2(src, dst, follow_symlinks=False)


def remove_entry(path: Path) -> None:
    if path.is_dir() and not path.is_symlink():
        shutil.rmtree(path)
    elif path.exists() or path.is_symlink():
        path.unlink()


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Detach ~/.cargo from DotCortex and keep live Cargo state in $HOME."
    )
    parser.add_argument(
        "--repo-home",
        default=str(Path.home() / "DotCortex/all/.cargo"),
        help="repo-owned cargo path to migrate away from",
    )
    parser.add_argument(
        "--home",
        default=str(Path.home() / ".cargo"),
        help="real cargo home destination",
    )
    parser.add_argument(
        "--keep-repo-copy",
        action="store_true",
        help="do not remove migrated live state from the repo path",
    )
    args = parser.parse_args()

    repo_home = Path(args.repo_home).expanduser().resolve()
    home = Path(args.home).expanduser()

    if not repo_home.exists():
        print(f"repo cargo path missing: {repo_home}")
        return 0

    migrated = 0
    if home.is_symlink():
        home.unlink()
    home.mkdir(parents=True, exist_ok=True)

    for src in sorted(repo_home.iterdir()):
        if src.name in SKIP:
            continue
        dst = home / src.name
        copy_entry(src, dst)
        migrated += 1
        if not args.keep_repo_copy:
            remove_entry(src)

    if not args.keep_repo_copy:
        leftovers = [p.name for p in repo_home.iterdir() if p.name not in SKIP]
        if leftovers:
            print(f"left repo leftovers untouched: {', '.join(leftovers)}")

    print(f"detached cargo home: migrated={migrated} home={home} repo={repo_home}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
