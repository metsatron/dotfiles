#!/usr/bin/env bash
# Profile directories
# We keep explicit profile prefixes under =~/.guix-extra-profiles= so nothing bleeds into your main profile unless you choose so.
# #+NAME: guix-dirs

# [[file:../../../guix.org::guix-dirs][guix-dirs]]
set -euo pipefail
# Add any profiles you plan to use here:
profiles=(core dev)

for name in "${profiles[@]}"; do
  base="$HOME/.guix-extra-profiles/$name"
  mkdir -p "$base"
  echo "Ensured: $base"
done
# guix-dirs ends here
