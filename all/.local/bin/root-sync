#!/usr/bin/env bash
# Root sync - copy configs from dotfiles into root
# This script syncs select configs from your dotfiles into root’s home. It auto-detects root’s home.


# [[file:../../../root.org::*Root sync - copy configs from dotfiles into root][Root sync - copy configs from dotfiles into root:1]]
set -euo pipefail

ROOT_HOME="$(getent passwd root | cut -d: -f6)"
: "${ROOT_HOME:=/root}"

# what to sync
declare -a ITEMS=(
  "$HOME/.dotfiles/all/.config/guix/channels.scm"
  "$HOME/.dotfiles/all/.config/guix/manifests/root.scm"
  "$HOME/.dotfiles/all/.config/nvim/"
)

for src in "${ITEMS[@]}"; do
  if [[ -e "$src" ]]; then
    dest="${ROOT_HOME}${src#"$HOME"}"
    sudo install -d -m 0755 "$(dirname "$dest")"
    # Use rsync for dirs, install for files
    if [[ -d "$src" ]]; then
      sudo rsync -a --delete "$src" "$dest"
    else
      sudo install -m 0644 "$src" "$dest"
    fi
    sudo chown -R root:root "${dest%/}"
    echo "Synced: $src -> $dest"
  else
    echo "Skip missing: $src"
  fi
done
# Root sync - copy configs from dotfiles into root:1 ends here
