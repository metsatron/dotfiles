#!/usr/bin/env bash
# Apply manifest inside DotCortex env

# [[file:../../../cargo.org::*Apply manifest inside DotCortex env][Apply manifest inside DotCortex env:1]]
#!/usr/bin/env bash
set -euo pipefail

MAN="$HOME/DotCortex/all/.cargo/manifest/crates.ssv"

# Default runner (your existing choice)
RUN="$HOME/.local/bin/dotcortex-rust-env"

# Host-link runner (Guix toolchain, host libs)
HOST_RUN="$HOME/.local/bin/cargo-wrap"

DEFAULT_LANE="${DEFAULT_LANE:-host}"

ENFORCE="${ENFORCE:-1}"
UNINSTALL="${UNINSTALL:-1}"

echo "== cargo apply =="

_emit_norm() {
  awk -v FS='[ \t]+' '
    function dequote(s){ return (s=="\"\"" ? "" : s) }
    $0 ~ /^[ \t]*#/ || NF==0 { next }
    {
      c1=$1; c2=$2; c3=$3; c4=$4; c5=$5; c6=$6; c7=$7; c8=$8; c9=$9;
      printf "%s\0%s\0%s\0%s\0%s\0%s\0%s\0%s\0%s\0",
        dequote(c1),dequote(c2),dequote(c3),dequote(c4),
        dequote(c5),dequote(c6),dequote(c7),dequote(c8),dequote(c9)
    }
  ' "$MAN"
}

while IFS= read -r -d '' crate \
   && IFS= read -r -d '' version \
   && IFS= read -r -d '' features \
   && IFS= read -r -d '' bins \
   && IFS= read -r -d '' source \
   && IFS= read -r -d '' git_url \
   && IFS= read -r -d '' git_ref \
   && IFS= read -r -d '' target \
   && IFS= read -r -d '' lane
do
  [[ -n "$crate" ]] || continue

  lane="${lane:-$DEFAULT_LANE}"

  args=(install "$crate")

  if [[ -n "$version" ]]; then
    args+=(--version "$version" --locked)
  fi

  [[ -n "$features" ]] && args+=(--features "$features")

  if [[ -n "$bins" ]]; then
    IFS=',' read -ra BB <<<"$bins"
    for b in "${BB[@]}"; do
      [[ -n "$b" ]] && args+=(--bin "$b")
    done
  fi

  [[ -n "$target" ]] && args+=(--target "$target")

  if [[ "${source:-crates.io}" = "git" && -n "${git_url:-}" ]]; then
    args+=(--git "$git_url")
    [[ -n "${git_ref:-}" ]] && args+=(--rev "$git_ref")
  fi

  if [[ "$lane" = "host" ]]; then
    "$HOST_RUN" "${args[@]}"
  else
    "$RUN" cargo "${args[@]}"
  fi
done < <(_emit_norm)

if [[ "$ENFORCE" = 1 && "$UNINSTALL" = 1 ]]; then
  echo "== uninstall extras =="

  want_tmp="$(mktemp)"
  have_tmp="$(mktemp)"

  awk '!/^[[:space:]]*#/ && NF { print $1 }' "$MAN" | sort -u >"$want_tmp"

  "$RUN" cargo install --list 2>/dev/null \
    | awk '/^[^[:space:]]+ v[0-9]+\.[0-9]+\.[0-9]+:/ { print $1 }' \
    | sort -u >"$have_tmp"

  comm -13 "$want_tmp" "$have_tmp" | while read -r extra; do
    [[ -n "$extra" ]] || continue
    "$RUN" cargo uninstall "$extra" || true
  done

  rm -f "$want_tmp" "$have_tmp"
fi

echo "Done."
# Apply manifest inside DotCortex env:1 ends here
