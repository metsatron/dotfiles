#!/usr/bin/env bash
set -euo pipefail

# 1) Tangle everything
emacs --batch -Q \
  --eval '(load-file "~/.local/bin/dotfiles-batch.el")' \
  --eval '(require '"'"'org)' --eval '(require '"'"'ob-tangle)' \
  --eval '(org-babel-tangle-file (expand-file-name "laincore.org"))'

# 2) Run computed emitters (needs lc/* defs and no prompts)
emacs --batch -Q laincore.org \
  --eval '(require '"'"'org)' \
  --eval '(require '"'"'ob-emacs-lisp)' \
  --eval '(setq org-confirm-babel-evaluate nil)' \
  --eval '(org-babel-goto-named-src-block "lc-bootstrap")' \
  --eval '(org-babel-execute-src-block)' \
  --eval '(org-babel-goto-named-src-block "emit-gtk3-settings-ini")' \
  --eval '(org-babel-execute-src-block)'
