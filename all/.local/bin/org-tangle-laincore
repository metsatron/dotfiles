#!/usr/bin/env bash
# [[file:../../../loom.org::*Maak control plane (Scheme, XDG-friendly)][Maak control plane (Scheme, XDG-friendly):5]]
# ~/.local/bin/org-tangle-laincore
#!/usr/bin/env bash
set -euo pipefail
emacs --batch -Q \
  --eval '(load-file "~/.local/bin/dotfiles-batch.el")' \
  --eval '(setq org-confirm-babel-evaluate nil)' \
  --eval '(require '"'"'org)' \
  --eval '(require '"'"'ob-emacs-lisp)' \
  --eval '(find-file "style.org")' \
  --eval '(org-babel-goto-named-src-block "loom-style")' \
  --eval '(org-babel-execute-src-block)'
# Maak control plane (Scheme, XDG-friendly):5 ends here
