#!/usr/bin/env bash
# [[file:../../../loom.org::*Maak control plane (Scheme, XDG-friendly)][Maak control plane (Scheme, XDG-friendly):6]]
# ~/.local/bin/org-tangle-laincore
#!/usr/bin/env bash
set -Eeuo pipefail
cd ~/DotCortex
exec emacs --batch -Q \
  --eval '(setq org-confirm-babel-evaluate nil create-lockfiles nil make-backup-files nil auto-save-default nil default-directory (expand-file-name "~/DotCortex/"))' \
  --eval '(load-file "~/.local/bin/dotfiles-batch.el")' \
  --eval '(require '"'"'org)' \
  --eval '(require '"'"'ob-emacs-lisp)' \
  --eval '(find-file "style.org")' \
  --eval '(org-babel-goto-named-src-block "loom-style")' \
  --eval '(org-babel-execute-src-block)'
# Maak control plane (Scheme, XDG-friendly):6 ends here
