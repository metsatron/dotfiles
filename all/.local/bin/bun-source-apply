#!/usr/bin/env bash
# Apply Bun source builds with conditional install/build

# [[file:../../../bun.org::*Apply Bun source builds with conditional install/build][Apply Bun source builds with conditional install/build:1]]
# ~/DotCortex/all/.local/bin/bun-source-apply
set -euo pipefail

source "$HOME/.local/bin/dotcortex-bun-source-lib"

echo "== bun source apply =="

seen=0
while IFS=$'\t' read -r name mode root repo ref subdir install_cmd build_cmd health_cmd extra
do
  [ -n "$name" ] || continue
  if [ -n "$BUN_SOURCE_ONLY" ] && [ "$name" != "$BUN_SOURCE_ONLY" ]; then
    continue
  fi

  seen=1
  bun_source_ensure_checkout 0 "$name" "$mode" "$root" "$repo" "$ref"

  root_abs="$(bun_source_root_abs "$root")"
  workdir_abs="$(bun_source_workdir_abs "$root" "$subdir")"
  state_dir="$(bun_source_state_dir "$name")"
  install_stamp="$state_dir/install.fp"
  build_stamp="$state_dir/build.fp"

  install_effective="$(bun_source_effective_install_cmd "$root_abs" "$workdir_abs" "$install_cmd")"
  build_effective="$(bun_source_effective_build_cmd "$build_cmd")"

  if [ -n "$install_effective" ]; then
    install_fp="$(bun_source_install_fingerprint "$root_abs" "$workdir_abs" "$install_effective")"
    if bun_source_fingerprint_matches "$install_stamp" "$install_fp"; then
      echo ">> [$name] install current"
    else
      bun_source_run_step "$name" install "$workdir_abs" "$install_effective"
      bun_source_write_fingerprint "$install_stamp" "$install_fp"
    fi
  else
    echo ">> [$name] install disabled"
  fi

  if [ -n "$build_effective" ]; then
    build_fp="$(bun_source_build_fingerprint "$root_abs" "$workdir_abs" "$install_effective" "$build_effective")"
    if bun_source_fingerprint_matches "$build_stamp" "$build_fp"; then
      echo ">> [$name] build current"
    else
      bun_source_run_step "$name" build "$workdir_abs" "$build_effective"
      bun_source_write_fingerprint "$build_stamp" "$build_fp"
    fi
  else
    echo ">> [$name] build disabled"
  fi
done < <(bun_source_rows)

if [ "$seen" = "0" ]; then
  echo "No Bun source builds defined in $BUN_SOURCE_MANIFEST"
fi

echo "Done."
# Apply Bun source builds with conditional install/build:1 ends here
