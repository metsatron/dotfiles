#!/usr/bin/env bash
#!/usr/bin/env bash
set -euo pipefail

TPM_DIR="${HOME}/.config/tmux/plugins/tpm"
RESURRECT_DIR="${HOME}/.local/share/tmux/resurrect"
TMUX_BIN="${HOME}/.guix-extra-profiles/core/core/bin/tmux"
[ -x "$TMUX_BIN" ] || TMUX_BIN="$(command -v tmux 2>/dev/null || true)"
if [ -z "$TMUX_BIN" ]; then
  echo "ERROR: tmux not found" >&2; exit 1
fi

echo "== tmux apply =="

mkdir -p "$RESURRECT_DIR"

if [ ! -d "$TPM_DIR" ]; then
  echo ">> Installing TPM..."
  git clone https://github.com/tmux-plugins/tpm "$TPM_DIR"
  echo ">> TPM installed at $TPM_DIR"
else
  echo ">> TPM already present at $TPM_DIR"
fi

if [ -x "$TPM_DIR/bin/install_plugins" ]; then
  # TPM install_plugins needs a running tmux server
  STARTED_SERVER=0
  if ! "$TMUX_BIN" list-sessions &>/dev/null; then
    echo ">> Starting temporary tmux server..."
    "$TMUX_BIN" new-session -d -s _tpm_bootstrap
    STARTED_SERVER=1
  fi

  echo ">> Installing tmux plugins..."
  PATH="$(dirname "$TMUX_BIN"):$PATH" "$TPM_DIR/bin/install_plugins"
  echo ">> Plugins installed."

  if [ "$STARTED_SERVER" -eq 1 ]; then
    "$TMUX_BIN" kill-session -t _tpm_bootstrap 2>/dev/null || true
  fi
else
  echo ">> TPM install script not found. Start tmux and press prefix + I."
fi

echo "Done."
