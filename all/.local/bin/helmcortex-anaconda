#!/usr/bin/env bash
# HelmCortex Anaconda Activate Wrapper

# [[file:../../../helmcortex.org::*HelmCortex Anaconda Activate Wrapper][HelmCortex Anaconda Activate Wrapper:1]]
set -euo pipefail

# keep non-Guix runtime for this process
unset GUIX_PROFILE GUIX_LOCPATH GUIX_GTK3_PATH LD_LIBRARY_PATH

# activate env for this process
# use source so we do not spawn a subshell
source "$HOME/HelmCortex/FORGE/bin/helmcortex-anaconda-activate"

if [[ "${1-}" == "-c" ]]; then
  shift
  exec python -c "$@"
elif [[ "${1-}" == *.py ]]; then
  script="$1"; shift
  exec python "$script" "$@"
else
  exec python "$@"
fi
# HelmCortex Anaconda Activate Wrapper:1 ends here
