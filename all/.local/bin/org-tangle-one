#!/usr/bin/env bash
# [[file:../../../loom.org::*Maak control plane (Scheme, XDG-friendly)][Maak control plane (Scheme, XDG-friendly):4]]
# ~/.local/bin/org-tangle-one
#!/usr/bin/env bash
set -Eeuo pipefail
file="${1:?Usage: org-tangle-one <file.org>}"
echo ">> Tangle $file"

if [[ "$(basename "$file")" == "style.org" ]]; then
  exec emacs --batch -Q \
    --eval "(setq org-confirm-babel-evaluate nil create-lockfiles nil make-backup-files nil auto-save-default nil)" \
    --eval "(require 'org)" \
    --eval "(require 'ob-emacs-lisp)" \
    --eval "(find-file \"$file\")" \
    --eval "(org-babel-goto-named-src-block \"loom-style\")" \
    --eval "(org-babel-execute-src-block)"
else
  exec emacs --batch -Q \
    --eval "(setq org-confirm-babel-evaluate nil create-lockfiles nil make-backup-files nil auto-save-default nil)" \
    --eval "(find-file \"$file\")" \
    --eval "(org-babel-tangle)"
fi
# Maak control plane (Scheme, XDG-friendly):4 ends here
