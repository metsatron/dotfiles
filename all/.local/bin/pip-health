#!/usr/bin/env bash
# Health

# [[file:../../../pip.org::*Health][Health:1]]
# ~/DotCortex/all/.local/bin/pip-health
set -euo pipefail

echo "PYTHON    = /usr/bin/python3"
echo "PIP       = $(/usr/bin/python3 -m pip --version 2>/dev/null || echo n/a)"
echo "python ver= $(/usr/bin/python3 --version 2>/dev/null || echo n/a)"
echo "pip ver   = $(/usr/bin/python3 -m pip --version 2>/dev/null || echo n/a)"
echo ""
echo "User packages: $(/usr/bin/python3 -m pip list --user --format=freeze 2>/dev/null | wc -l)"
echo "Total packages: $(/usr/bin/python3 -m pip list --format=freeze 2>/dev/null | wc -l)"
# Health:1 ends here
