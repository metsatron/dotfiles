#!/usr/bin/env bash
#!/usr/bin/env bash
set -euo pipefail

RESURRECT_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/tmux/resurrect"
LAST_LINK="${RESURRECT_DIR}/last"
LOCKDIR="${RESURRECT_DIR}/.save-safe.lock"
UPSTREAM_SAVE="${HOME}/.config/tmux/plugins/tmux-resurrect/scripts/save.sh"

candidate_name() {
  printf 'tmux_resurrect_%s.txt\n' "$(date +"%Y%m%dT%H%M%S")"
}

acquire_lock() {
  mkdir -p "$RESURRECT_DIR"
  while ! mkdir "$LOCKDIR" 2>/dev/null; do
    sleep 0.1
  done
  trap 'rmdir "$LOCKDIR"' EXIT
}

wait_for_fresh_timestamp() {
  local candidate current_last
  while :; do
    candidate="$(candidate_name)"
    current_last="$(readlink "$LAST_LINK" 2>/dev/null || true)"
    if [ "$candidate" != "$current_last" ] && [ ! -e "${RESURRECT_DIR}/${candidate}" ]; then
      return 0
    fi
    sleep 1
  done
}

repair_last_link() {
  local latest
  if [ -L "$LAST_LINK" ] && [ -e "$LAST_LINK" ]; then
    return 0
  fi
  latest="$(ls -1t "$RESURRECT_DIR"/tmux_resurrect_*.txt 2>/dev/null | head -1 || true)"
  if [ -n "$latest" ]; then
    ln -sfn "$(basename "$latest")" "$LAST_LINK"
  fi
}

main() {
  if [ ! -x "$UPSTREAM_SAVE" ]; then
    echo "tmux-resurrect-save-safe: upstream save script not found at $UPSTREAM_SAVE" >&2
    exit 1
  fi

  acquire_lock
  wait_for_fresh_timestamp
  "$UPSTREAM_SAVE" "$@"
  repair_last_link
}

main "$@"
