#!/usr/bin/env bash
# Plan diff

# [[file:../../../cargo.org::*Plan diff][Plan diff:1]]
# ~/DotCortex/all/.local/bin/cargo-diff
set -euo pipefail

MAN="$HOME/DotCortex/all/.local/share/dotcortex/manifests/cargo/crates.ssv"
RUN="$HOME/.local/bin/dotcortex-rust-env"

tmp_want="$(mktemp)"
tmp_have="$(mktemp)"

awk '!/^[[:space:]]*#/ && NF { print $1 }' "$MAN" | sort -u >"$tmp_want"

"$RUN" cargo install --list 2>/dev/null \
  | awk '/^[^[:space:]]+ v[0-9]+\.[0-9]+\.[0-9]+:/ { print $1 }' \
  | sort -u >"$tmp_have"

echo "== cargo plan =="
echo "[to install]"
comm -23 "$tmp_want" "$tmp_have" | sed 's/^/  + /'

echo "[to uninstall]"
comm -13 "$tmp_want" "$tmp_have" | sed 's/^/  - /'

rm -f "$tmp_want" "$tmp_have"
# Plan diff:1 ends here
