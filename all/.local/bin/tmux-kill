#!/usr/bin/env bash
#!/usr/bin/env bash
# tmux-kill — kill local and remote tmux sessions via fzf
# Usage: tmux-kill [HOST:SESSION | SESSION]
#   No args  → fzf multi-select of all live sessions (local + remote)
#   SESSION  → kill local session directly
#   HOST:SESSION → kill remote session via SSH

REGISTRY="${XDG_CONFIG_HOME:-$HOME/.config}/tmux/sessions.ssv"

kill_session() {
  local spec="$1"
  if [[ "$spec" == *:* ]]; then
    local host="${spec%%:*}"
    local session="${spec#*:}"
    ssh "$host" "tmux kill-session -t '$session'" 2>/dev/null \
      && echo "Killed: $session on $host" \
      || echo "Failed: $session on $host" >&2
  else
    tmux kill-session -t "$spec" 2>/dev/null \
      && echo "Killed: $spec (local)" \
      || echo "Failed: $spec (local)" >&2
  fi
}

# --- Direct mode ---
if [[ -n "$1" ]]; then
  kill_session "$1"
  exit $?
fi

if ! command -v fzf >/dev/null 2>&1; then
  echo "tmux-kill: fzf required for interactive mode" >&2
  exit 1
fi

# --- Gather sessions ---
LINES=""

# Local sessions
while IFS= read -r line; do
  name=$(echo "$line" | awk -F: '{ print $1 }')
  info=$(echo "$line" | sed 's/^[^:]*: //')
  LINES+="$(printf '%-20s %-10s %s' "$name" "(local)" "$info")"$'\n'
done < <(tmux list-sessions 2>/dev/null)

# Remote sessions — query each unique remote host from the registry
if [[ -f "$REGISTRY" ]]; then
  while IFS= read -r host; do
    while IFS= read -r line; do
      name=$(echo "$line" | awk -F: '{ print $1 }')
      info=$(echo "$line" | sed 's/^[^:]*: //')
      LINES+="$(printf '%-20s %-10s %s' "$host:$name" "($host)" "$info")"$'\n'
    done < <(ssh -o ConnectTimeout=3 "$host" 'tmux list-sessions 2>/dev/null' 2>/dev/null)
  done < <(grep -v '^#' "$REGISTRY" | awk '$2 != "local" { print $2 }' | sort -u)
fi

if [[ -z "$LINES" ]]; then
  echo "No tmux sessions running."
  exit 0
fi

SELECTED=$(echo "$LINES" | sed '/^$/d' | fzf --multi --prompt="tmux-kill> " --height=~15 --reverse | awk '{ print $1 }')

if [[ -z "$SELECTED" ]]; then
  exit 0
fi

while IFS= read -r spec; do
  kill_session "$spec"
done <<< "$SELECTED"
