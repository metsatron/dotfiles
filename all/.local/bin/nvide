#!/usr/bin/env bash
set -u

neovide --x11-wm-class-instance nv --x11-wm-class NeovideNV "$@" &
app_pid=$!

# Wait for the window to exist
for i in {1..50}; do
  wid=$(xdotool search --class NeovideNV 2>/dev/null | head -n1 || true)
  [ -n "${wid:-}" ] && break
  sleep 0.1
done

# Force maximize if we found the window
if [ -n "${wid:-}" ]; then
  wmctrl -i -r "$wid" -b add,maximized_vert,maximized_horz
fi

wait "$app_pid"
