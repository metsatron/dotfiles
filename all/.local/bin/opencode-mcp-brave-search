#!/usr/bin/env bash
# OpenCode - Brave Search
# The OpenCode global config lives at =~/.config/opencode/opencode.json=.
# Project-local config lives at =.opencode/opencode.json=. Manage the global
# config in =hooks.org=, then bring it home with =make safe-stow=.


# [[file:../../../mcp.org::*OpenCode - Brave Search][OpenCode - Brave Search:1]]
# ~/DotCortex/all/.local/bin/opencode-mcp-brave-search
set -euo pipefail

if [ -r "$HOME/.env" ]; then
  # shellcheck source=/dev/null
  . "$HOME/.env"
fi

: "${BRAVE_API_KEY:?BRAVE_API_KEY must be set in \$HOME/.env}"

if ! command -v npx >/dev/null 2>&1; then
  echo "opencode-mcp-brave-search: npx not found in PATH." >&2
  exit 1
fi

export BRAVE_API_KEY

exec npx -y @modelcontextprotocol/server-brave-search
# OpenCode - Brave Search:1 ends here
