#!/usr/bin/env bash
# Apply manifest

# [[file:../../../pip.org::*Apply manifest][Apply manifest:1]]
# ~/DotCortex/all/.local/bin/pip-apply
set -euo pipefail

MAN="$HOME/DotCortex/all/.pip/manifest/packages.ssv"

echo "== pip apply =="

while IFS= read -r line; do
  # Skip comments and blanks
  [[ "$line" =~ ^[[:space:]]*# ]] && continue
  [[ -z "${line// /}" ]] && continue

  pkg="$(echo "$line" | awk '{ print $1 }')"
  version="$(echo "$line" | awk '{ print $2 }' | tr -d '"')"

  [ -z "$pkg" ] && continue

  spec="$pkg"
  [ -n "$version" ] && spec="$pkg==$version"

  if /usr/bin/python3 -m pip show "$pkg" &>/dev/null; then
    echo "  ok: $pkg"
  else
    echo "  installing: $spec"
    /usr/bin/python3 -m pip install --user "$spec"
  fi
done <"$MAN"

echo "Done."
# Apply manifest:1 ends here
