#!/usr/bin/env bash
# Health

# [[file:../../../npm.org::*Health][Health:1]]
# ~/DotCortex/all/.local/bin/npm-health
set -euo pipefail

"$HOME/DotCortex/all/.local/bin/dotcortex-node-env" bash -c '
echo "NODE      = $(command -v node || echo missing)"
echo "NPM       = $(command -v npm || echo missing)"
echo "node ver  = $(node --version 2>/dev/null || echo n/a)"
echo "npm ver   = $(npm --version 2>/dev/null || echo n/a)"
echo "NPM_CONFIG_PREFIX=${NPM_CONFIG_PREFIX:-}"
echo "npm prefix= $(npm config get prefix 2>/dev/null || echo n/a)"
'
# Health:1 ends here
