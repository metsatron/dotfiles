#!/usr/bin/env bash
# [[file:../../../README.org::*Maak control plane (Scheme, XDG-friendly)][Maak control plane (Scheme, XDG-friendly):2]]
set -euo pipefail
CONF="${XDG_CONFIG_HOME:-$HOME/.config}/maak/maak.scm"
GUIX_GUILE="$HOME/.guix-extra-profiles/core/core/bin/guile"
export GUILE_AUTO_COMPILE=0
exec "$GUIX_GUILE" -e main -s "$CONF" "$@"
# Maak control plane (Scheme, XDG-friendly):2 ends here
