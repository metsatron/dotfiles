#!/usr/bin/env bash
# [[file:../../../README.org::*Maak control plane (Scheme, XDG-friendly)][Maak control plane (Scheme, XDG-friendly):2]]
set -euo pipefail
CONF="${XDG_CONFIG_HOME:-$HOME/.config}/maak/maak.scm"
exec guile -e main -s "$CONF" "$@"
