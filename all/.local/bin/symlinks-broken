#!/usr/bin/env bash
# symlinks-broken — enumerate broken symlinks under a root (default: $HOME)
# Outputs to stdout and appends a timestamped report to ~/broken-symlinks.log
# Safe for weird filenames; does not dereference symlinks when traversing.

set -Eeuo pipefail

ROOT="${1:-$HOME}"
LOG="${HOME}/broken-symlinks.log"

timestamp() { date -Is; }

# emit one record
emit_record() {
  local link_path="$1"
  # raw target as stored in the symlink (may be relative)
  local raw_target
  raw_target="$(readlink -- "$link_path" || true)"

  # normalize to an absolute path without requiring the target to exist
  # - if raw target is absolute, keep it; otherwise resolve against link's dir
  local abs_target
  if [[ "$raw_target" = /* ]]; then
    abs_target="$(realpath -m -- "$raw_target" 2>/dev/null || printf '%s' "$raw_target")"
  else
    abs_target="$(realpath -m -- "$(dirname -- "$link_path")/$raw_target" 2>/dev/null || printf '%s' "$raw_target")"
  fi

  printf 'LINK    : %s\n' "$link_path"
  printf 'TARGET  : %s\n' "${raw_target:-<no target>}"
  printf 'ABS PATH: %s\n' "$abs_target"
  printf 'STATUS  : BROKEN\n'
  printf '\n'
}

main() {
  printf '===== broken-symlinks scan: %s =====\n\n' "$(timestamp)" | tee -a "$LOG" >/dev/null

  # Use -type l to visit symlinks themselves; then test -e to detect broken ones.
  # -print0 protects against spaces/newlines; silence permission errors under $HOME just in case.
  broken_count=0
  while IFS= read -r -d '' link; do
    if [[ ! -e "$link" ]]; then
      out="$(emit_record "$link")"
      # show on screen and append to log
      printf '%s' "$out" | tee -a "$LOG"
      broken_count=$((broken_count + 1))
    fi
  done < <(find -H "$ROOT" -type l -print0 2>/dev/null)

  summary=$(printf 'TOTAL BROKEN: %d (root: %s)\n\n' "$broken_count" "$ROOT")
  printf '%s' "$summary" | tee -a "$LOG"
}

main "$@"
