#!/usr/bin/env bash
# Health for Bun source builds

# [[file:../../../bun.org::*Health for Bun source builds][Health for Bun source builds:1]]
# ~/DotCortex/all/.local/bin/bun-source-health
set -euo pipefail

source "$HOME/.local/bin/dotcortex-bun-source-lib"

echo "== bun source health =="
echo "Manifest   = $BUN_SOURCE_MANIFEST"
echo "State root = $BUN_SOURCE_STATE_ROOT"
echo "BUN        = $(command -v bun || echo missing)"
echo "bun ver    = $(bun_source_bun_version_or_missing)"

seen=0
while IFS=$'\t' read -r name mode root repo ref subdir install_cmd build_cmd health_cmd extra
do
  [ -n "$name" ] || continue
  if [ -n "$BUN_SOURCE_ONLY" ] && [ "$name" != "$BUN_SOURCE_ONLY" ]; then
    continue
  fi

  seen=1
  root_abs="$(bun_source_root_abs "$root")"
  workdir_abs="$(bun_source_workdir_abs "$root" "$subdir")"
  state_dir="$(bun_source_state_dir "$name")"
  install_stamp="$state_dir/install.fp"
  build_stamp="$state_dir/build.fp"
  install_effective=""
  build_effective=""
  health_effective="$(bun_source_effective_health_cmd "$health_cmd")"

  echo "-- $name"
  echo "   mode    = $mode"
  echo "   root    = $root_abs"
  echo "   workdir = $workdir_abs"
  [ -n "$repo" ] && echo "   repo    = $repo"
  [ -n "$ref" ] && echo "   ref     = $ref"
  [ -n "$extra" ] && echo "   extra   = $extra"

  if [ -d "$root_abs" ] && bun_source_is_git_repo "$root_abs"; then
    echo "   head    = $(git -C "$root_abs" rev-parse --short HEAD 2>/dev/null || echo unknown)"
    if [ -n "$(git -C "$root_abs" status --porcelain=v1 --untracked-files=normal 2>/dev/null || true)" ]; then
      echo "   tree    = dirty"
    else
      echo "   tree    = clean"
    fi
  elif [ -d "$root_abs" ]; then
    echo "   tree    = present"
  else
    echo "   tree    = missing"
  fi

  if [ -d "$workdir_abs" ]; then
    install_effective="$(bun_source_effective_install_cmd "$root_abs" "$workdir_abs" "$install_cmd")"
    if [ -n "$install_effective" ]; then
      install_fp="$(bun_source_install_fingerprint "$root_abs" "$workdir_abs" "$install_effective")"
      if bun_source_fingerprint_matches "$install_stamp" "$install_fp"; then
        echo "   install = current"
      else
        echo "   install = stale"
      fi
    else
      echo "   install = disabled"
    fi

    build_effective="$(bun_source_effective_build_cmd "$build_cmd")"
    if [ -n "$build_effective" ]; then
      build_fp="$(bun_source_build_fingerprint "$root_abs" "$workdir_abs" "$install_effective" "$build_effective")"
      if bun_source_fingerprint_matches "$build_stamp" "$build_fp"; then
        echo "   build   = current"
      else
        echo "   build   = stale"
      fi
    else
      echo "   build   = disabled"
    fi

    if [ -n "$health_effective" ]; then
      if [ "${RUN_CHECKS:-0}" = "1" ]; then
        bun_source_run_step "$name" health "$workdir_abs" "$health_effective"
      else
        echo "   health  = configured (set RUN_CHECKS=1 to execute)"
      fi
    fi
  else
    echo "   install = unavailable"
    echo "   build   = unavailable"
  fi
done < <(bun_source_rows)

if [ "$seen" = "0" ]; then
  echo "No Bun source builds defined in $BUN_SOURCE_MANIFEST"
fi
# Health for Bun source builds:1 ends here
