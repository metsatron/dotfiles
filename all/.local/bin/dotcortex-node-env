#!/usr/bin/env bash
# Isolated Node env for DotCortex

# [[file:../../../npm.org::*Isolated Node env for DotCortex][Isolated Node env for DotCortex:1]]
# ~/.dotfiles/all/.local/bin/dotcortex-node-env
#!/usr/bin/env bash
set -euo pipefail

export NPM_CONFIG_PREFIX="${NPM_CONFIG_PREFIX:-$HOME/.npm-global}"

# Ensure the prefix directories exist for npm
if [ ! -d "$NPM_CONFIG_PREFIX/lib/node_modules" ]; then
  mkdir -p "$NPM_CONFIG_PREFIX/lib/node_modules"
fi

# then whatever you already do to activate fnm / node / PATH

exec "$@"
# Isolated Node env for DotCortex:1 ends here
