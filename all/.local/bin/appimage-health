#!/usr/bin/env bash
# Health check: only one integrator and it’s ours

# [[file:../../../appimage.org::*Health check: only one integrator and it’s ours][Health check: only one integrator and it’s ours:1]]
set -Eeuo pipefail
echo "== Integrator processes =="
pgrep -af appimaged || echo "(none)"
pgrep -af appimagelauncher || echo "(no AIL)"
echo "== appimaged status =="
systemctl --user status appimaged --no-pager || true
echo "== recent logs =="
journalctl --user -u appimaged -n 50 --no-pager || true
# Health check: only one integrator and it’s ours:1 ends here
