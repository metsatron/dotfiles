#!/usr/bin/env bash
# Sync Bun source checkouts without rebuilding

# [[file:../../../bun.org::*Sync Bun source checkouts without rebuilding][Sync Bun source checkouts without rebuilding:1]]
# ~/DotCortex/all/.local/bin/bun-source-sync
set -euo pipefail

source "$HOME/.local/bin/dotcortex-bun-source-lib"

echo "== bun source sync =="

seen=0
while IFS=$'\t' read -r name mode root repo ref subdir install_cmd build_cmd health_cmd extra
do
  [ -n "$name" ] || continue
  if [ -n "$BUN_SOURCE_ONLY" ] && [ "$name" != "$BUN_SOURCE_ONLY" ]; then
    continue
  fi

  seen=1
  bun_source_ensure_checkout 0 "$name" "$mode" "$root" "$repo" "$ref"
done < <(bun_source_rows)

if [ "$seen" = "0" ]; then
  echo "No Bun source builds defined in $BUN_SOURCE_MANIFEST"
fi
# Sync Bun source checkouts without rebuilding:1 ends here
