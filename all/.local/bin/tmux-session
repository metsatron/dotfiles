#!/usr/bin/env bash
#!/usr/bin/env bash
# tmux-session — DotCortex tmux session launcher
# Usage: tmux-session [TARGET]
#   No args  → fzf selector (interactive) or local Cortex (non-interactive)
#   TARGET   → look up in ~/.config/tmux/sessions.ssv

REGISTRY="${XDG_CONFIG_HOME:-$HOME/.config}/tmux/sessions.ssv"
HOST="$(hostname)"

# Purge Claude Code nesting guard from tmux global env.
# Claude sets CLAUDECODE=1 in child processes; if launched inside tmux,
# that leaks into the global env and blocks new claude launches in any pane.
tmux set-environment -g -u CLAUDECODE 2>/dev/null

# --- Dispatch a registry target ---
dispatch_target() {
  local TARGET="$1"

  if [[ ! -f "$REGISTRY" ]]; then
    echo "tmux-session: registry not found: $REGISTRY" >&2
    exit 1
  fi

  local RHOST RSESSION RDIR
  read -r _ RHOST RSESSION RDIR < <(
    grep -v '^#' "$REGISTRY" | awk -v t="$TARGET" '$1 == t { print; exit }'
  )

  if [[ -z "$RHOST" ]]; then
    echo "tmux-session: unknown target '$TARGET'" >&2
    echo "Available targets:" >&2
    grep -v '^#' "$REGISTRY" | awk '{ print "  " $1 }' >&2
    exit 1
  fi

  if [[ "$RHOST" == "local" ]]; then
    if tmux has-session -t "$RSESSION" 2>/dev/null; then
      exec tmux attach-session -t "$RSESSION"
    fi
    tmux new-session -d -s "$RSESSION" -c "$HOME/$RDIR"
    exec tmux attach-session -t "$RSESSION"
  else
    exec ssh "$RHOST" -t \
      'cd ~/'"$RDIR"' && tmux new-session -A -s '"$RSESSION"
  fi
}

# --- Explicit target ---
if [[ -n "$1" ]]; then
  dispatch_target "$1"
fi

# --- Interactive fzf selector (no args, tty attached) ---
if [[ -t 0 && -f "$REGISTRY" ]] && command -v fzf >/dev/null 2>&1; then
  TARGET=$(
    grep -v '^#' "$REGISTRY" | awk '{ printf "%-20s %s@%s  ~/%s\n", $1, $3, $2, $4 }' \
      | fzf --prompt="tmux-session> " --height=~10 --reverse \
      | awk '{ print $1 }'
  )
  if [[ -n "$TARGET" ]]; then
    dispatch_target "$TARGET"
  fi
  exit 0
fi

# --- Default: local Cortex session with cross-machine windows ---
SESSION="Cortex"

if tmux has-session -t "$SESSION" 2>/dev/null; then
  exec tmux attach-session -t "$SESSION"
fi

if [[ "$HOST" == *T480s* || "$HOST" == *t480s* ]]; then
  tmux new-session -d -s "$SESSION" -n "t480s" -c "$HOME/DotCortex"
  tmux new-window  -t "$SESSION" -n "x230"
  tmux send-keys -t "$SESSION:x230" "ssh x230 -t 'tmux attach -t Cortex 2>/dev/null || tmux new -s Cortex'" Enter

elif [[ "$HOST" == *X230* || "$HOST" == *x230* ]]; then
  tmux new-session -d -s "$SESSION" -n "x230" -c "$HOME/DotCortex"
  tmux new-window  -t "$SESSION" -n "t480s"
  tmux send-keys -t "$SESSION:t480s" "ssh t480s -t 'tmux attach -t Cortex 2>/dev/null || tmux new -s Cortex'" Enter

else
  tmux new-session -d -s "$SESSION" -n "main" -c "$HOME/DotCortex"
fi

tmux select-window -t "$SESSION:1"
exec tmux attach-session -t "$SESSION"
