#!/usr/bin/env bash
set -Eeuo pipefail

# ===== Defaults / flags =====
MODE="" AUTO=0 DO_PIP_USER=0 CARGO_UP_ALL=0
FLATPAK_FIX=1 FLATPAK_UNPIN=0
NPM_MODE="user"   # user|root|auto|skip (default: user)

# ===== Arg parsing (single block) =====
while (($#)); do
  case "$1" in
    -n|--dry|--dry-run)           MODE="dry" ;;
    -y|--yes)                     MODE="yes" ;;
    --auto)                       AUTO=1 ;;
    --pip-user)                   DO_PIP_USER=1 ;;
    --cargo-upgrade-all)          CARGO_UP_ALL=1 ;;
    --npm-mode)                   NPM_MODE="${2:?auto|user|root|skip}"; shift ;;
    --flatpak-no-fix)             FLATPAK_FIX=0 ;;
    --flatpak-unpin)              FLATPAK_UNPIN=1 ;;
    -h|--help)
      cat <<'EOF'
Usage: pkg-update-all [-n|--dry-run] [-y|--yes] [--auto]
                      [--pip-user] [--cargo-upgrade-all]
                      [--npm-mode auto|user|root|skip]
                      [--flatpak-no-fix] [--flatpak-unpin]

Defaults:
  - Nala/Apt/Snap/Flatpak: pretty TTY via `script` + full log
  - Flatpak: preflight fixes runtimes (ON); optional unpin (OFF)
  - NPM: user (fnm-managed Node); switch with --npm-mode
  - Cargo: list only; --cargo-upgrade-all to rebuild
  - pip user-site: OFF; enable with --pip-user
EOF
      exit 0 ;;
    *) echo "ERROR: Unknown arg: $1" >&2; exit 1 ;;
  esac
  shift
done

# Flatpak scope toggles
FLATPAK_UPDATE_USER="${FLATPAK_UPDATE_USER:-1}"     # default: user only
FLATPAK_UPDATE_SYSTEM="${FLATPAK_UPDATE_SYSTEM:-0}" # default: no system

# Sudo precheck toggle (kept available but OFF by default)
REQUIRE_SUDO_PRECHECK="${REQUIRE_SUDO_PRECHECK:-0}"

# Guix behavior
GUIX_PULL="${GUIX_PULL:-0}"  # default: skip 'guix pull' (faster)
GUIX_PROFILES_DEFAULT="$HOME/.guix-extra-profiles/core/core $HOME/.guix-extra-profiles/dev/dev"
GUIX_PROFILES="${GUIX_PROFILES:-$GUIX_PROFILES_DEFAULT}"

# ===== Helpers =====
die(){ echo "ERROR: $*" >&2; exit 1; }
have(){ command -v "$1" >/dev/null 2>&1; }
npm_is_root() {
  local pfx bin
  pfx="$(npm config get prefix 2>/dev/null || true)"
  bin="$(command -v npm 2>/dev/null || true)"
  [[ "$pfx" == "/usr/local" || "$bin" == "/usr/local/bin/npm" ]]
}

LOG="/tmp/pkg_update_all_$(date +%Y%m%d_%H%M%S).log"
touch "$LOG" || true

run_tty() {  # preserve UI (Nala/Flatpak) and log
  local cmd="$*"
  echo "+ $cmd"
  [ "${MODE:-}" = "dry" ] && return 0
  script -q -a "$LOG" -c "$cmd"
}

run_pipe() {
  local cmd="$*"
  echo "+ $cmd"
  [ "${MODE:-}" = "dry" ] && return 0
  bash -lc "$cmd" | tee -a "$LOG"
}

# Run a whole batch in ONE sudo PTY (reduces re-prompts)
run_sudo_block() {
  local block="$*"
  echo "+ (sudo block) $block"
  [ "${MODE:-}" = "dry" ] && return 0
  script -q -a "$LOG" -c "sudo bash -lc '$block'"
}

# ===== Detection (NO sudo here) =====
echo "=== Detected managers ==="
det=()
if have nala; then det+=("nala"); elif have apt; then det+=("apt"); fi
have snap    && det+=("snap")
have flatpak && det+=("flatpak")
have pipx    && det+=("pipx")
[ "$DO_PIP_USER" -eq 1 ] && have python3 && det+=("pip(user)")
( have rustup || have cargo ) && det+=("rustup/cargo")
have npm     && det+=("npm")
echo "${det[*]:-(none)}"
[ "${#det[@]}" -eq 0 ] && { echo "Nothing to do."; exit 0; }

# ===== Confirm =====
if (( ! AUTO )); then
  read -rp "Proceed? [y/N] " ans
  case "${ans,,}" in y|yes) :;; *) echo "Aborted."; exit 0;; esac
else
  [ -n "${MODE:-}" ] || die "--auto requires -n or -y"
fi

# ===== Decide if we actually need sudo this run =====
SUDO_NEEDED=0
if have nala || have apt || have snap; then
  SUDO_NEEDED=1
fi
if have flatpak && [ "$FLATPAK_UPDATE_SYSTEM" = 1 ]; then
  SUDO_NEEDED=1
fi
if [ "$REQUIRE_SUDO_PRECHECK" = 1 ]; then
  SUDO_NEEDED=1
fi

# ===== Sudo keep-alive (AFTER confirm, ONLY if needed) =====
if (( SUDO_NEEDED )) && command -v sudo >/dev/null 2>&1 && [ "${MODE:-}" != "dry" ]; then
  # one upfront prompt
  sudo -v
  # keep alive during the session
  ( while true; do sleep 45; sudo -n true || exit; done ) 2>/dev/null &
  SUDO_KEEPALIVE_PID=$!
  trap 'kill ${SUDO_KEEPALIVE_PID:-0} 2>/dev/null || true' EXIT
fi

# ===== Nala/Apt (one sudo block) =====
if have nala; then
  run_sudo_block 'nala full-upgrade -y; nala autoremove --purge -y'
elif have apt; then
  run_sudo_block 'apt update; apt -y full-upgrade; apt -y autoremove --purge'
fi

# ===== Snap =====
if have snap; then
  run_pipe "snap refresh --list"
  run_sudo_block "snap refresh"
fi

# ===== Flatpak (explicit system + user) =====

ensure_flathub() {
  if [ "$FLATPAK_UPDATE_SYSTEM" = 1 ]; then
    run_sudo_block 'flatpak remote-add --if-not-exists --system flathub https://flathub.org/repo/flathub.flatpakrepo'
  fi
  run_pipe 'flatpak --user remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo'
}

install_needed_runtimes() {
  local scope="$1" who=""
  [ "$scope" = "--system" ] && who="sudo"

  local reqs base branch ref
  reqs=$(flatpak list "$scope" --app --columns=runtime 2>/dev/null | awk 'NF' | sort -u) || true
  [ -z "$reqs" ] && return 0

  while IFS= read -r r; do
    base="${r%/*/*}"
    branch="${r##*/}"
    ref="${base}//${branch}"
    if [ "$who" = "sudo" ]; then
      run_sudo_block "flatpak install -y $scope flathub \"$ref\" || true"
    else
      run_tty        "flatpak install -y $scope flathub \"$ref\" || true"
    fi
  done <<< "$reqs"
}

if command -v flatpak >/dev/null 2>&1; then
  ensure_flathub

  if [ "$FLATPAK_FIX" -eq 1 ] && [ "${MODE:-}" != "dry" ]; then
    [ "$FLATPAK_UPDATE_SYSTEM" = 1 ] && install_needed_runtimes --system
    [ "$FLATPAK_UPDATE_USER"   = 1 ] && install_needed_runtimes --user

    run_pipe "flatpak pin --system || true"
    run_pipe "flatpak pin --user   || true"
    if [ "$FLATPAK_UNPIN" -eq 1 ]; then
      run_tty "flatpak pin --remove --system runtime/org.gnome.Platform/x86_64/43 || true"
      run_tty "flatpak pin --remove --system runtime/org.gnome.Platform/x86_64/45 || true"
      run_tty "flatpak pin --remove --user   runtime/org.gnome.Platform/x86_64/43 || true"
      run_tty "flatpak pin --remove --user   runtime/org.gnome.Platform/x86_64/45 || true"
    fi
  fi

  if [ "${MODE:-}" = "dry" ]; then
    [ "$FLATPAK_UPDATE_SYSTEM" = 1 ] && run_tty 'flatpak remote-ls --updates --system || true'
    [ "$FLATPAK_UPDATE_USER"   = 1 ] && run_tty 'flatpak remote-ls --updates --user   || true'
  else
    [ "$FLATPAK_UPDATE_SYSTEM" = 1 ] && run_sudo_block 'flatpak update -y --system; flatpak uninstall -y --unused --system || true'
    [ "$FLATPAK_UPDATE_USER"   = 1 ] && run_tty       'flatpak update -y --user;   flatpak uninstall -y --unused --user   || true'
  fi
fi

# ===== Guix (user profiles) =====
if have guix; then
  if [ "$GUIX_PULL" = 1 ]; then
    run_pipe "guix pull"
  fi

  # Update the classic default profile if present
  [ -e "$HOME/.guix-profile" ] && run_pipe "guix package --profile=\"$HOME/.guix-profile\" -u || true"

  # Update the profiles you actually use (core/dev by default)
  for prof in $GUIX_PROFILES; do
    [ -e "$prof" ] || continue
    run_pipe "guix package --profile=\"$prof\" -u || true"
  done

  # Optional GC
  # run_pipe "guix gc"
fi

# ===== pip (user-site, opt-in) =====
if [ "$DO_PIP_USER" -eq 1 ] && have python3; then
  if [ "${MODE:-}" = "dry" ]; then
    run_pipe "python3 -m pip list --user --outdated"
  else
    run_tty  "bash -lc 'python3 -m pip list --user --outdated --format=freeze | cut -d= -f1 | xargs -r -n1 python3 -m pip install --user -U'"
  fi
fi

# ===== rustup / cargo =====
if have rustup; then
  if [ "${MODE:-}" = "dry" ]; then
    run_pipe "rustup show"
  else
    run_pipe  "rustup self update || true"   # simple pipe output is fine here
    run_tty   "rustup update"                # pretty progress
  fi
fi
if have cargo; then
  if [ "$CARGO_UP_ALL" -eq 1 ]; then
    if [ "${MODE:-}" = "dry" ]; then
      run_pipe "cargo install --list"
    else
      run_tty "bash -lc 'cargo install --list | sed -n \"s/^\([^ ]\\+\\) v.*/\\1/p\" | xargs -r -n1 cargo install --force'"
    fi
  else
    run_pipe "cargo install --list"
  fi
fi

# ===== npm (fnm-managed Node recommended) =====
if have npm; then
  case "$NPM_MODE" in
    skip) : ;;
    root)
      if [ "${MODE:-}" = "dry" ]; then
        run_pipe "sudo npm -g outdated --depth=0 || true"
      else
        run_tty  "sudo npm -g update || true"
      fi
      ;;
    auto)
      if npm_is_root; then
        if [ "${MODE:-}" = "dry" ]; then
          run_pipe "sudo npm -g outdated --depth=0 || true"
        else
          run_tty  "sudo npm -g update || true"
        fi
      else
        if [ "${MODE:-}" = "dry" ]; then
          run_pipe "npm -g outdated --depth=0 || true"
        else
          run_tty  "npm -g update || true"
        fi
      fi
      ;;
    user|*)
      if [ "${MODE:-}" = "dry" ]; then
        run_pipe "npm -g outdated --depth=0 || true"
      else
        run_tty  "npm -g update || true"
      fi
      ;;
  esac
fi

echo "[✓] Finished. Log: $LOG"
