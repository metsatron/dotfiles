#!/usr/bin/env bash
set -Eeuo pipefail

# czk – unified dedupe wrapper:
# - Prefer czkawka_cli (fast + features)
# - Fallbacks: jdupes (hardlink), rdfind (hardlink)
# - --bootstrap  : install czkawka_cli with cargo-binstall (prebuilt) or cargo (compile)
# - --version    : print tool versions actually used

die(){ echo "ERROR: $*" >&2; exit 1; }
have(){ command -v "$1" >/dev/null 2>&1; }

bootstrap() {
  # Try cargo-binstall (prebuilt) first; otherwise, install rustup+cargo, then cargo install.
  if ! have cargo-binstall; then
    if have curl; then
      curl -fsSL https://raw.githubusercontent.com/cargo-bins/cargo-binstall/main/install-from-binstall-release.sh | bash
    elif have wget; then
      wget -qO- https://raw.githubusercontent.com/cargo-bins/cargo-binstall/main/install-from-binstall-release.sh | bash
    else
      echo "[*] Need curl or wget for cargo-binstall bootstrap; skipping binstall."
    fi
    export PATH="$HOME/.cargo/bin:$PATH"
  fi

  if have cargo-binstall; then
    echo "[*] Installing czkawka_cli via cargo-binstall (prebuilt)…"
    cargo-binstall -y czkawka_cli || echo "[warn] cargo-binstall failed; will try cargo."
  fi

  if ! have czkawka_cli; then
    if ! have rustup; then
      echo "[*] Installing rustup (user-local)…"
      if have curl; then
        curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
      else
        wget -qO- https://sh.rustup.rs | sh -s -- -y
      fi
      export PATH="$HOME/.cargo/bin:$PATH"
    fi
    rustup self update || true
    rustup update
    echo "[*] Installing czkawka_cli via cargo (first time compiles; subsequent runs reuse cache)…"
    cargo install czkawka_cli    # NOTE: no --force so it WON'T rebuild each run
  fi

  command -v czkawka_cli && czkawka_cli --version || die "czkawka_cli install failed"
  exit 0
}

show_versions() {
  if have czkawka_cli; then czkawka_cli --version; else echo "czkawka_cli: not found"; fi
  if have jdupes; then jdupes --version | head -n1; else echo "jdupes: not found"; fi
  if have rdfind; then rdfind -v | head -n1; else echo "rdfind: not found"; fi
  exit 0
}

case "${1:-}" in
  --bootstrap) bootstrap ;;
  --version)   show_versions ;;
esac

# Prefer czkawka_cli for dedupe (example defaults):
# - Example: czk --hardlink /path/A /path/B
#   Uses czkawka_cli duplicates finder with hardlink post action
if have czkawka_cli; then
  # pass through to czkawka_cli; add your typical args here if you like
  exec czkawka_cli "$@"
fi

# Fallbacks
if have jdupes; then
  echo "[info] czkawka_cli not found; using jdupes."
  # Common operations:
  #   preview: jdupes -rS PATHS...
  #   hardlink: jdupes -rL PATHS...
  exec jdupes "$@"
fi

if have rdfind; then
  echo "[info] czkawka_cli/jdupes not found; using rdfind."
  exec rdfind "$@"
fi

die "No czkawka_cli (or jdupes/rdfind) found. Try: czk --bootstrap"
