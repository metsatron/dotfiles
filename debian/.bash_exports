# ~/.bash_exports
# --------------------------------------------------
# Mètsàtron's Exports
# --------------------------------------------------

# Example custom variables
export EDITOR='vim'
export BROWSER='floorp'

[ -e /usr/lib/x86_64-linux-gnu/libgtk3-nocsd.so.0 ] && export LD_PRELOAD=/usr/lib/x86_64-linux-gnu/libgtk3-nocsd.so.0
# export LD_PRELOAD=/usr/lib/x86_64-linux-gnu/libgtk3-nocsd.so.0
export GTK_CSD=0

# don't put duplicate lines or lines starting with space in the history.
HISTCONTROL=ignoreboth

# history length
HISTSIZE=10000
HISTFILESIZE=20000

# Lesspipe
[ -x /usr/bin/lesspipe ] && eval "$(SHELL=/bin/sh lesspipe)"

# GCC colors (commented)
#export GCC_COLORS='error=01;31:warning=01;35:note=01;36:caret=01;32:locus=01:quote=01'

# ProtonUp-Qt PATH addition
if [ -d "/home/metsatron/stl/prefix" ]; then export PATH="$PATH:/home/metsatron/stl/prefix"; fi
