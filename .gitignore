 .directory

# editor backups
*~
all/.spacemacs.d.claude/.cache/

# Mutable package-manager homes must stay in $HOME, not DotCortex
all/.cargo/
all/.bun/
all/.bunx/

# Emacs build/package caches
all/.emacs.d/eln-cache/
all/.emacs.d/elpa/
all/.config/emacs/.local/
all/.emacs.profiles/**/.cache/
all/.emacs.profiles/**/.spacemacs.d.claude/.cache/
.eask/

# Desktop icon caches and temp files
*.icon-theme.cache
*/icon-theme.cache

# Goneovim sessions
linux/.config/goneovim/sessions/

# Local app caches that should not be canon
linux/.qmmp/playlist.txt
.#*
#*#
*~
.#*
#*#
*~

# Fonts Cache
*.uuid

# Font binary assets — large, not tracked in git (managed on disk via stow)
all/.local/share/fonts/

# OpenCode runtime state
.opencode/opencode.db

# Guix live profile symlink — machine-specific, points into /var/guix/
all/.config/guix/current

# TPM runtime plugins — installed by tmux-bootstrap, not repo-managed
all/.config/tmux/plugins/
